#!/bin/bash
# cld-observe-any - 汎用 session-watch ツール（多指標 AND 条件でイベント発火）
# Usage: cld-observe-any --window <name>|--pattern <regex> [OPTIONS]
set -euo pipefail

if [[ -n "${_TEST_MODE:-}" ]] && [[ -n "${CLD_OBSERVE_ANY_SCRIPT_DIR:-}" ]]; then
    SCRIPT_DIR="$CLD_OBSERVE_ANY_SCRIPT_DIR"
else
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
fi

# LLM 思考 indicator 定数リスト（Claude Code UI 変更時はここを更新）
# AC1: Claude Code 4.x 追加 indicator
# AC2: 一般化 regex "[A-Z][a-z]+(in'|ing|ed)(…| for [0-9]| \([0-9])" で未知 indicator をカバー
LLM_INDICATORS=(
    "Thinking"
    "Brewing"
    "Brewed"
    "Concocting"
    "Ebbing"
    "Proofing"
    "Frosting"
    "Reasoning"
    "Computing"
    "Planning"
    "Composing"
    "Processing"
    "Running .* agents"
    "[0-9]+ tool uses"
    "thinking with max effort"
    "Saut.*ed"
    "Burrowing"
    "Cerebrating"
    "Spinning"
    "Beboppin"
    "Thundering"
    "Baked"
    "Cooked"
    "Crunched"
    "Churned"
    "Skedaddling"
    "Orchestrating"
    "[A-Z][a-z]+(in'|ing|ed)(…| for [0-9]| \\([0-9])"
)

# --- デフォルト値 ---
WINDOWS=()
PATTERNS=()
INTERVAL=20
LOG_DIR=""
FORMAT="text"
COMPLETE_REGEX=""
COMPLETE_REQUIRE_CMD_ECHO=""
BUDGET_THRESHOLD=15
STAGNATE_SEC=300
EVENT_DIR=""
NOTIFY_DIR=""
MAX_CYCLES=0
ONCE=false

usage() {
    cat <<'EOF'
Usage: cld-observe-any (--window <name> | --pattern <regex>) [OPTIONS]

Options:
  --window <name>                  監視対象 tmux window 名（複数指定可）
  --pattern <regex>                window 名マッチング正規表現（複数指定可）
  --interval <sec>                 ポーリング間隔（デフォルト: 20）
  --log-dir <path>                 pipe-pane log 探索ディレクトリ
  --format <json|text>             出力形式（デフォルト: text）
  --complete-regex <regex>         [PHASE-COMPLETE] 検知用フレーズ正規表現
  --complete-require-cmd-echo <r>  [PHASE-COMPLETE] コマンドエコー確定用正規表現（opt-in）
  --budget-threshold <min>         [BUDGET-LOW] 閾値（分、デフォルト: 15）
  --stagnate-sec <N>               [STAGNATE] 閾値（秒、デフォルト: 300）
  --event-dir <path>               イベントファイル書き出しディレクトリ（opt-in）
  --notify-dir <path>              /tmp/claude-notifications 互換通知ディレクトリ
  --max-cycles <N>                 最大サイクル数（0 = 無制限）
  --once                           単一回実行して exit
  -h, --help                       ヘルプ表示
EOF
    exit 0
}

# --- 引数解析 ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        --window)
            [[ -z "${2:-}" ]] && { echo "Error: --window requires a value" >&2; exit 1; }
            WINDOWS+=("$2"); shift 2 ;;
        --pattern)
            [[ -z "${2:-}" ]] && { echo "Error: --pattern requires a value" >&2; exit 1; }
            PATTERNS+=("$2"); shift 2 ;;
        --interval)
            [[ -z "${2:-}" ]] && { echo "Error: --interval requires a value" >&2; exit 1; }
            INTERVAL="$2"
            [[ "$INTERVAL" =~ ^[1-9][0-9]*$ ]] || { echo "Error: --interval requires a positive integer" >&2; exit 1; }
            shift 2 ;;
        --log-dir)
            [[ -z "${2:-}" ]] && { echo "Error: --log-dir requires a value" >&2; exit 1; }
            LOG_DIR="$2"; shift 2 ;;
        --format)
            [[ -z "${2:-}" ]] && { echo "Error: --format requires a value" >&2; exit 1; }
            FORMAT="$2"
            [[ "$FORMAT" == "json" || "$FORMAT" == "text" ]] || { echo "Error: --format must be json or text" >&2; exit 1; }
            shift 2 ;;
        --complete-regex)
            [[ -z "${2:-}" ]] && { echo "Error: --complete-regex requires a value" >&2; exit 1; }
            COMPLETE_REGEX="$2"; shift 2 ;;
        --complete-require-cmd-echo)
            [[ -z "${2:-}" ]] && { echo "Error: --complete-require-cmd-echo requires a value" >&2; exit 1; }
            COMPLETE_REQUIRE_CMD_ECHO="$2"; shift 2 ;;
        --budget-threshold)
            [[ -z "${2:-}" ]] && { echo "Error: --budget-threshold requires a value" >&2; exit 1; }
            BUDGET_THRESHOLD="$2"; shift 2 ;;
        --stagnate-sec)
            [[ -z "${2:-}" ]] && { echo "Error: --stagnate-sec requires a value" >&2; exit 1; }
            STAGNATE_SEC="$2"; shift 2 ;;
        --event-dir)
            [[ -z "${2:-}" ]] && { echo "Error: --event-dir requires a value" >&2; exit 1; }
            EVENT_DIR="$2"; shift 2 ;;
        --notify-dir)
            [[ -z "${2:-}" ]] && { echo "Error: --notify-dir requires a value" >&2; exit 1; }
            NOTIFY_DIR="$2"; shift 2 ;;
        --max-cycles)
            [[ -z "${2:-}" ]] && { echo "Error: --max-cycles requires a value" >&2; exit 1; }
            MAX_CYCLES="$2"
            [[ "$MAX_CYCLES" =~ ^[0-9]+$ ]] || { echo "Error: --max-cycles requires a non-negative integer" >&2; exit 1; }
            shift 2 ;;
        --once)
            ONCE=true; shift ;;
        -h|--help)
            usage ;;
        -*)
            echo "Error: unknown option '$1'" >&2; exit 1 ;;
        *)
            echo "Error: unexpected argument '$1'" >&2; exit 1 ;;
    esac
done

if [[ ${#WINDOWS[@]} -eq 0 && ${#PATTERNS[@]} -eq 0 ]]; then
    echo "Error: --window または --pattern を指定してください" >&2
    exit 1
fi

# --- flock 多重起動防止 ---
LOCK_FILE="/tmp/cld-observe-any.lock"
exec 9>"$LOCK_FILE"
if ! flock -n 9; then
    existing_pid=$(cat "$LOCK_FILE.pid" 2>/dev/null || echo "?")
    echo "[cld-observe-any] ERROR: 既存 instance が起動中 (PID=$existing_pid)" >&2
    exit 1
fi
echo $$ > "$LOCK_FILE.pid"
trap 'rm -f "$LOCK_FILE.pid"' EXIT

# --- クリーンアップ ---
TMPFILES=()
cleanup() {
    for f in "${TMPFILES[@]:-}"; do
        rm -f "$f" 2>/dev/null || true
    done
}
trap cleanup EXIT
trap 'echo ""; echo "[cld-observe-any] SIGINT/SIGTERM 受信 → 終了"; cleanup; exit 0' INT TERM

# --- ユーティリティ ---

# ANSI エスケープ除去
strip_ansi() {
    sed 's/\x1b\[[0-9;]*[a-zA-Z]//g'
}

# タイムスタンプ取得
now_hms() {
    date '+%H:%M:%S'
}

now_iso() {
    date -u '+%Y-%m-%dT%H:%M:%SZ'
}

# ログ最新 mtime (秒) 計算。log_dir 未指定または log なし → 999
get_log_age() {
    local win="$1"
    local min_age=999
    [[ -z "$LOG_DIR" ]] && echo "$min_age" && return

    local f age
    while IFS= read -r f; do
        [[ -f "$f" ]] || continue
        age=$(( $(date +%s) - $(stat -c %Y "$f" 2>/dev/null || echo 0) ))
        [[ $age -lt $min_age ]] && min_age=$age
    done < <(find "$LOG_DIR" -maxdepth 2 -name "*${win}*.log" 2>/dev/null || true)
    echo "$min_age"
}

# A2: LLM 思考 indicator 検出。見つかれば単語を返す
detect_thinking() {
    local tail15="$1"
    local w
    for w in "${LLM_INDICATORS[@]}"; do
        if echo "$tail15" | grep -qiE "$w"; then
            echo "$w"
            return
        fi
    done
    echo ""
}

# A6: budget 残量（分）取得。-1 = 取得不能
get_budget_minutes() {
    local win="$1"
    local raw
    raw=$(tmux capture-pane -t "$win" -p -S -1 2>/dev/null \
        | grep -oP '(?:budget|Budget):\s*\K[0-9]+[hm]' | tail -1 || echo "")
    if [[ -z "$raw" ]]; then
        raw=$(tmux capture-pane -t "$win" -p -S -60 2>/dev/null \
            | grep -oP '(?:budget|Budget):\s*\K[0-9]+[hm]' | tail -1 || echo "")
    fi
    if [[ -z "$raw" ]]; then
        echo "-1"; return
    fi
    if [[ "$raw" =~ ^([0-9]+)h$ ]]; then
        echo $(( ${BASH_REMATCH[1]} * 60 ))
    elif [[ "$raw" =~ ^([0-9]+)m$ ]]; then
        echo "${BASH_REMATCH[1]}"
    else
        echo "-1"
    fi
}

# イベント emit（stdout + opt-in event-dir 書き出し）
emit_event() {
    local event="$1"
    local win="$2"
    local thinking="${3:-}"
    local log_age="${4:-999}"
    local state="${5:-unknown}"
    local budget="${6:--1}"

    local ts
    ts=$(now_hms)
    local iso
    iso=$(now_iso)

    if [[ "$FORMAT" == "json" ]]; then
        jq -nc \
            --arg event "$event" \
            --arg window "$win" \
            --arg ts "$iso" \
            --arg thinking "${thinking:-null}" \
            --argjson log_age "$log_age" \
            --arg state "$state" \
            --argjson budget "$budget" \
            '{event: $event, window: $window, timestamp: $ts, thinking: (if $thinking == "null" then null else $thinking end), log_age: $log_age, state: $state, budget: $budget}'
    else
        echo "[$event] ${ts} window=${win} thinking=${thinking:-<empty>} log_age=${log_age}s state=${state} budget=${budget}"
    fi

    # opt-in: --event-dir 書き出し
    if [[ -n "$EVENT_DIR" ]]; then
        mkdir -p "$EVENT_DIR" 2>/dev/null || true
        local fname
        fname="${EVENT_DIR}/${event}-${win}-$(date -u +%Y%m%dT%H%M%SZ).json"
        local tmpf
        tmpf=$(mktemp "${EVENT_DIR}/.ev-XXXXXX" 2>/dev/null || mktemp)
        TMPFILES+=("$tmpf")
        # session_id: .supervisor/session.json から取得を試みる
        local session_id=""
        session_id=$(jq -r '.session_id // empty' ".supervisor/session.json" 2>/dev/null || echo "")
        jq -nc \
            --arg event "$event" \
            --arg window "$win" \
            --arg session_id "$session_id" \
            --arg ts "$iso" \
            --arg thinking "${thinking:-null}" \
            --argjson log_age "$log_age" \
            --arg state "$state" \
            --argjson budget "$budget" \
            '{event: $event, window: $window, session_id: $session_id, timestamp: $ts, thinking: (if $thinking == "null" then null else $thinking end), log_age: $log_age, state: $state, budget: $budget}' > "$tmpf"
        mv "$tmpf" "$fname" 2>/dev/null || true
    fi
}

# 通知ファイル確認（cld-observe-loop 互換）
check_notifications() {
    local win="$1"
    [[ -z "$NOTIFY_DIR" ]] && return 1
    [[ -d "$NOTIFY_DIR" ]] || return 1

    local found=false notify_file state seen
    while IFS= read -r notify_file; do
        [[ -f "$notify_file" ]] || continue
        local content
        content=$(cat "$notify_file" 2>/dev/null) || continue
        state=$(echo "$content" | jq -r '.state // empty' 2>/dev/null) || continue
        [[ "$state" == "attention" ]] || continue
        seen=$(echo "$content" | jq -r '.seen // "null"' 2>/dev/null) || continue
        if [[ "$seen" != "true" ]]; then
            found=true
            echo "[NOTIFY] $notify_file: state=attention seen=$seen"
        fi
    done < <(find "$NOTIFY_DIR" -maxdepth 1 -name "${win}:*.json" 2>/dev/null || true)
    [[ "$found" == "true" ]]
}

# 監視対象 window リスト取得
get_target_windows() {
    local wins=()

    # --window で明示指定されたもの
    for w in "${WINDOWS[@]:-}"; do
        [[ -n "$w" ]] && wins+=("$w")
    done

    # --pattern で glob マッチするもの
    if [[ ${#PATTERNS[@]} -gt 0 ]]; then
        local all_windows
        all_windows=$(tmux list-windows -a -F '#{window_name}' 2>/dev/null || true)
        local name
        while IFS= read -r name; do
            [[ -z "$name" ]] && continue
            local pat
            for pat in "${PATTERNS[@]}"; do
                if echo "$name" | grep -qE "$pat" 2>/dev/null; then
                    wins+=("$name")
                    break
                fi
            done
        done <<< "$all_windows"
    fi

    # 重複除去
    local seen=()
    local w
    for w in "${wins[@]:-}"; do
        local dup=false
        local s
        for s in "${seen[@]:-}"; do
            [[ "$s" == "$w" ]] && { dup=true; break; }
        done
        [[ "$dup" == "false" ]] && { seen+=("$w"); echo "$w"; }
    done
}

# --- 1 window の評価 ---
evaluate_window() {
    local win="$1"

    # tmux target 解決
    local target
    target=$(tmux list-windows -a -F '#{session_name}:#{window_index} #{window_name}' 2>/dev/null \
        | awk -v n="$win" '$2 == n { print $1; exit }')
    if [[ -z "$target" ]]; then
        # --window 指定で見つからない場合は PANE-DEAD 相当として報告
        emit_event "PANE-DEAD" "$win" "" "999" "exited" "-1"
        return
    fi

    # A4: pane_dead + pane_current_command
    local pane_info
    pane_info=$(tmux display-message -t "$target" -p '#{pane_dead} #{pane_current_command}' 2>/dev/null || echo "0 unknown")
    local pane_dead pane_cmd
    pane_dead="${pane_info%% *}"
    pane_cmd="${pane_info#* }"

    if [[ "$pane_dead" == "1" ]]; then
        emit_event "PANE-DEAD" "$win" "" "999" "exited" "-1"
        return
    fi

    # A1: capture-pane scrollback 60行、ANSI strip
    local full tail15
    full=$(tmux capture-pane -t "$target" -p -S -60 2>/dev/null | strip_ansi)
    tail15=$(echo "$full" | tail -15)

    # A2: LLM indicator 検出
    local thinking
    thinking=$(detect_thinking "$tail15")

    # A3: log mtime age
    local log_age
    log_age=$(get_log_age "$win")

    # A5: session-state.sh（補助のみ）
    local state
    state=$("$SCRIPT_DIR/session-state.sh" state "$win" 2>/dev/null) || state="unknown"

    # A6: budget 残量
    local budget_min
    budget_min=$(get_budget_minutes "$target")

    # --- イベント判定（優先順位順） ---

    # [PANE-DEAD]
    # （上で処理済み）

    # [ERROR-STATE]: indicator 空 AND tail にエラーパターン
    if [[ -z "$thinking" ]]; then
        if echo "$tail15" | grep -qE 'Traceback|^bash: line|No such file or directory|command not found'; then
            emit_event "ERROR-STATE" "$win" "$thinking" "$log_age" "$state" "$budget_min"
            return
        fi
    fi

    # [BUDGET-LOW]
    if [[ "$budget_min" -ge 0 && "$budget_min" -le "$BUDGET_THRESHOLD" ]]; then
        emit_event "BUDGET-LOW" "$win" "$thinking" "$log_age" "$state" "$budget_min"
        # BUDGET-LOW は thinking 状態でも emit（優先）
        return
    fi

    # [PERMISSION-PROMPT]: thinking 中でも即時 emit（prompt は自動解消しないため thinking guard 前に配置）
    if echo "$tail15" | grep -qE '^([1-9]\. (Yes, proceed|Yes, and allow|No, and tell)|Interrupted by user)'; then
        emit_event "PERMISSION-PROMPT" "$win" "$thinking" "$log_age" "$state" "$budget_min"
        return
    fi

    # 以下: thinking がある場合は絶対 emit しない
    if [[ -n "$thinking" ]]; then
        return
    fi

    # [PHASE-COMPLETE]
    if [[ -n "$COMPLETE_REGEX" ]] && echo "$tail15" | grep -qE "$COMPLETE_REGEX"; then
        local cmd_ok=true
        if [[ -n "$COMPLETE_REQUIRE_CMD_ECHO" ]]; then
            echo "$tail15" | grep -qE "$COMPLETE_REQUIRE_CMD_ECHO" || cmd_ok=false
        fi
        if [[ "$cmd_ok" == "true" && "$log_age" -ge 30 ]]; then
            emit_event "PHASE-COMPLETE" "$win" "$thinking" "$log_age" "$state" "$budget_min"
            return
        fi
    fi

    # [REVIEW-READY]
    if echo "$tail15" | grep -qE 'Submit answers|Ready to submit'; then
        if [[ "$log_age" -ge 30 ]]; then
            emit_event "REVIEW-READY" "$win" "$thinking" "$log_age" "$state" "$budget_min"
            return
        fi
    fi

    # [MENU-READY]
    if echo "$tail15" | grep -qE 'Enter to select|Esc to cancel'; then
        if [[ "$log_age" -ge 30 ]]; then
            emit_event "MENU-READY" "$win" "$thinking" "$log_age" "$state" "$budget_min"
            return
        fi
    fi

    # [FREEFORM-READY]
    if echo "$tail15" | grep -qE 'よろしいですか|続けますか|進めますか|\[y/N\]|\[Y/n\]|Press up'; then
        if [[ "$log_age" -ge 30 ]]; then
            emit_event "FREEFORM-READY" "$win" "$thinking" "$log_age" "$state" "$budget_min"
            return
        fi
    fi

    # [STAGNATE]
    if [[ "$log_age" -ge "$STAGNATE_SEC" ]]; then
        emit_event "STAGNATE-${STAGNATE_SEC}" "$win" "$thinking" "$log_age" "$state" "$budget_min"
        return
    fi

    # 通知ファイル検知（cld-observe-loop 互換）
    if check_notifications "$win" 2>/dev/null; then
        emit_event "NOTIFY" "$win" "$thinking" "$log_age" "$state" "$budget_min"
    fi
}

# --- メインループ ---

CYCLE=0

# [IDLE-COMPLETED] 状態管理 — メインループスコープで宣言 (AC-5, Issue #1117)
# evaluate_window() は stateless 設計を維持するため、連想配列はここで管理する
declare -A IDLE_COMPLETED_TS

# _check_idle_completed() の SSOT を source する
# BASH_SOURCE[0] = plugins/session/scripts/cld-observe-any → ../twl/ = plugins/twl/
_IDLE_CHECK_LIB="$(dirname "${BASH_SOURCE[0]}")/../../twl/skills/su-observer/scripts/lib/observer-idle-check.sh"
if [[ -f "$_IDLE_CHECK_LIB" ]]; then
    # shellcheck source=/dev/null
    source "$_IDLE_CHECK_LIB"
fi

# --once モード: 現在状態を評価して exit
if [[ "$ONCE" == "true" ]]; then
    TARGET_WINS=()
    while IFS= read -r w; do
        [[ -n "$w" ]] && TARGET_WINS+=("$w")
    done < <(get_target_windows)

    for win in "${TARGET_WINS[@]:-}"; do
        evaluate_window "$win"
    done
    exit 0
fi

while true; do
    CYCLE=$((CYCLE + 1))

    TARGET_WINS=()
    while IFS= read -r w; do
        [[ -n "$w" ]] && TARGET_WINS+=("$w")
    done < <(get_target_windows)

    local_count=${#TARGET_WINS[@]}
    if [[ $local_count -eq 0 ]]; then
        break
    fi

    # 20 window 超過の警告
    if [[ $local_count -gt 20 ]]; then
        echo "[cld-observe-any] WARNING: 監視対象 ${local_count} window（推奨上限: 20）" >&2
    fi

    for win in "${TARGET_WINS[@]}"; do
        evaluate_window "$win"
    done

    # [IDLE-COMPLETED] 判定 — evaluate_window() 外のメインループ内に配置 (AC-5)
    # stateless _check_idle_completed() に IDLE_COMPLETED_TS を渡す
    if declare -f _check_idle_completed &>/dev/null; then
        NOW=$(date +%s)
        for WIN in "${TARGET_WINS[@]}"; do
            # ANSI strip を strip_ansi() に統一 (evaluate_window() と同じ CSI 全除去)
            PANE_CONTENT=$(tmux capture-pane -t "$WIN" -p -S -60 2>/dev/null | strip_ansi || true)
            FIRST_SEEN="${IDLE_COMPLETED_TS[$WIN]:-0}"

            if _check_idle_completed "$PANE_CONTENT" "$FIRST_SEEN" "$NOW" "${IDLE_COMPLETED_DEBOUNCE_SEC:-60}"; then
                # emit_event() に統一: --format json 時の出力形式を他チャネルと揃える
                emit_event "IDLE-COMPLETED" "$WIN" "" "$(( NOW - FIRST_SEEN ))" "idle-confirmed" "-1"
                if [[ -n "$EVENT_DIR" ]]; then
                    echo "{\"channel\":\"IDLE-COMPLETED\",\"window\":\"${WIN}\",\"elapsed_sec\":$((NOW - FIRST_SEEN)),\"ts\":${NOW}}" \
                        > "${EVENT_DIR}/idle-completed-${WIN//[^a-zA-Z0-9_-]/_}.json"
                fi
                # 60s ごとに継続 emit（observer が kill するまで繰り返す）
                IDLE_COMPLETED_TS[$WIN]=$NOW
                # opt-in auto-kill（IDLE_COMPLETED_AUTO_KILL=1 時のみ）
                if [[ "${IDLE_COMPLETED_AUTO_KILL:-0}" == "1" ]]; then
                    SAFE_WIN="${WIN//[^a-zA-Z0-9_-]/_}"
                    # evaluate_window() と同じ方法で session:index に解決し ambiguous target を回避
                    KILL_TARGET=$(tmux list-windows -a -F '#{session_name}:#{window_index} #{window_name}' 2>/dev/null \
                        | awk -v n="$WIN" '$2 == n { print $1; exit }')
                    if [[ -n "$KILL_TARGET" ]] && tmux kill-window -t "$KILL_TARGET" 2>/dev/null; then
                        echo "[IDLE-COMPLETED] $WIN: auto-killed (IDLE_COMPLETED_AUTO_KILL=1)"
                        if [[ -n "$EVENT_DIR" ]]; then
                            echo "{\"channel\":\"IDLE-COMPLETED-KILLED\",\"window\":\"${WIN}\",\"elapsed_sec\":$((NOW - FIRST_SEEN)),\"ts\":${NOW}}" \
                                > "${EVENT_DIR}/idle-completed-killed-${SAFE_WIN}-$(date -u +%Y%m%dT%H%M%SZ).json"
                        fi
                        unset 'IDLE_COMPLETED_TS[$WIN]'
                    else
                        echo "[IDLE-COMPLETED] $WIN: auto-kill failed (window already gone or permission denied)" >&2
                    fi
                fi
            else
                # completion phrase 初回検出 → first_seen_ts 記録
                # C3: detect_thinking() で LLM indicator 不在確認（Thinking 中は false trigger を防ぐ）
                # local は関数外で使用不可 (bash baseline §2) — 単純代入を使う
                _idle_thinking=$(detect_thinking "$(echo "$PANE_CONTENT" | tail -15)" 2>/dev/null || echo "")
                if [[ "${IDLE_COMPLETED_TS[$WIN]:-0}" -eq 0 ]] && \
                   [[ -z "$_idle_thinking" ]] && \
                   echo "$PANE_CONTENT" | grep -qE "${IDLE_COMPLETED_PHRASE_REGEX:-nothing pending}"; then
                    IDLE_COMPLETED_TS[$WIN]=$NOW
                fi
            fi
        done
    fi

    if [[ "$MAX_CYCLES" -gt 0 && "$CYCLE" -ge "$MAX_CYCLES" ]]; then
        break
    fi

    sleep "$INTERVAL"
done
