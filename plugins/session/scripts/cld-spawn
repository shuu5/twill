#!/bin/bash
# cld-spawn - Start a new Claude Code session in a new tmux window
#
# Usage:
#   cld-spawn [--cd DIR] [--window-name NAME] [--timeout N] [PROMPT]
#
# PROMPT は positional arg ではなく、起動後に wait-ready + inject-file で送達する。
# これにより改行・特殊文字を含むプロンプトが安全に渡せる。
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
# shellcheck source=./session-name.sh
source "$SCRIPT_DIR/session-name.sh"

# tmux check
if [[ -z "${TMUX:-}" ]]; then
    echo "Error: tmux内で実行してください" >&2
    exit 1
fi

CWD="$(pwd)"
CD_SPECIFIED=false
WINDOW_NAME=""
FORCE_NEW=0
WAIT_TIMEOUT=60

# Parse options
while [[ $# -gt 0 ]]; do
    case "$1" in
        --cd)
            [[ -z "${2:-}" ]] && { echo "Error: --cd にディレクトリを指定してください" >&2; exit 1; }
            CWD="$2"
            CD_SPECIFIED=true
            shift 2
            ;;
        --window-name)
            [[ -z "${2:-}" ]] && { echo "Error: --window-name に名前を指定してください" >&2; exit 1; }
            WINDOW_NAME="$2"
            shift 2
            ;;
        --force-new)
            FORCE_NEW=1
            shift
            ;;
        --timeout)
            [[ -z "${2:-}" ]] && { echo "Error: --timeout に秒数を指定してください" >&2; exit 1; }
            WAIT_TIMEOUT="$2"
            if ! [[ "$WAIT_TIMEOUT" =~ ^[1-9][0-9]*$ ]]; then
                echo "Error: --timeout には正の整数を指定してください" >&2
                exit 1
            fi
            shift 2
            ;;
        *)
            break
            ;;
    esac
done

# --cd 指定時のみチルダ展開・正規化・存在チェックを実行
if $CD_SPECIFIED; then
    CWD="${CWD/#\~/$HOME}"
    CWD="$(realpath -m "$CWD")"
    if [[ ! -d "$CWD" ]]; then
        echo "Error: ディレクトリが存在しません: $CWD" >&2
        exit 1
    fi
fi

# ウィンドウ名: 未指定時は意味論的命名（失敗時は時刻ベースにフォールバック）
if [[ -z "$WINDOW_NAME" ]]; then
    if ! WINDOW_NAME=$(generate_window_name wt "$CWD" "$CWD" 2>/dev/null); then
        WINDOW_NAME="wt-$(date +%H%M%S)-$$"
    fi
fi

# 残りの引数をプロンプトとして結合
PROMPT=""
if [[ $# -gt 0 ]]; then
    PROMPT="$*"
fi

# Build launcher script to avoid shell quoting issues with tmux
# cld は引数なしで起動（プロンプトは後から inject-file で送達）
LAUNCHER=$(mktemp /tmp/cld-spawn-XXXXXX.sh)
chmod +x "$LAUNCHER"

{
    echo '#!/bin/bash'
    echo "cd $(printf '%q' "$CWD") || exit 1"
    # CLD_PATH: テスト時のスタブ差し替え用（本番では未設定 → $SCRIPT_DIR/cld）
    printf '%q\n' "${CLD_PATH:-$SCRIPT_DIR/cld}"
    # Keep window open on error for diagnosis
    cat <<'TRAP'
EXIT_CODE=$?
if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "=== claude exited with code $EXIT_CODE ==="
    echo "Press Enter to close, or Ctrl-C to keep open."
    read -r || sleep 60
fi
TRAP
} > "$LAUNCHER"

# 同一 canonical_context の既存 window 再利用（--force-new 未指定時）
if [[ "$FORCE_NEW" -eq 0 ]]; then
    _EXISTING=$(find_existing_window "$WINDOW_NAME")
    if [[ -n "$_EXISTING" ]]; then
        rm -f "$LAUNCHER"
        tmux select-window -t "$_EXISTING"
        echo "reusing existing window: $_EXISTING ($WINDOW_NAME)"
        exit 0
    fi
fi

# 排他ロックで TOCTOU を防止しつつ new-window を実行
mkdir -p "$HOME/.local/state/twl"
exec 200>"$HOME/.local/state/twl/window-create.lock"
if ! flock -w 5 200; then
    rm -f "$LAUNCHER"
    echo "Error: ウィンドウ作成ロックを取得できませんでした" >&2
    exit 1
fi

# ロック内で再チェック（競合プロセスが先に作成した可能性）
if [[ "$FORCE_NEW" -eq 0 ]]; then
    _EXISTING=$(find_existing_window "$WINDOW_NAME")
    if [[ -n "$_EXISTING" ]]; then
        exec 200>&-
        rm -f "$LAUNCHER"
        tmux select-window -t "$_EXISTING"
        echo "reusing existing window: $_EXISTING ($WINDOW_NAME)"
        exit 0
    fi
fi

tmux new-window -n "$WINDOW_NAME" "bash '$LAUNCHER'; rm -f '$LAUNCHER'"
exec 200>&-  # ロック解放

# Verify window was created
sleep 0.5
if ! tmux list-windows -F '#{window_name}' | grep -qF "$WINDOW_NAME"; then
    rm -f "$LAUNCHER"
    echo "Error: tmux window の作成に失敗しました" >&2
    exit 1
fi

echo "spawned → tmux window '$WINDOW_NAME'"

# プロンプトがなければここで終了（対話モード起動のみ）
if [[ -z "$PROMPT" ]]; then
    exit 0
fi

# --- wait-ready + inject-file でプロンプトを送達 ---

# プロンプトを一時ファイルに書き出し
PROMPT_FILE=$(mktemp /tmp/cld-spawn-prompt-XXXXXX.txt)
printf '%s' "$PROMPT" > "$PROMPT_FILE"

# input-waiting 状態を待機
if ! "$SCRIPT_DIR/session-comm.sh" wait-ready "$WINDOW_NAME" --timeout "$WAIT_TIMEOUT"; then
    rm -f "$PROMPT_FILE"
    echo "Error: claude の起動待ちがタイムアウトしました（${WAIT_TIMEOUT}秒）" >&2
    exit 1
fi

# inject-file でプロンプトを送達
"$SCRIPT_DIR/session-comm.sh" inject-file "$WINDOW_NAME" "$PROMPT_FILE" --force
INJECT_EXIT=$?

rm -f "$PROMPT_FILE"

if [[ $INJECT_EXIT -ne 0 ]]; then
    echo "Error: プロンプトの送達に失敗しました" >&2
    exit 1
fi

echo "prompt injected → '$WINDOW_NAME'"
