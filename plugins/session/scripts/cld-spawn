#!/bin/bash
# cld-spawn - Start a new Claude Code session in a new tmux window
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"

# tmux check
if [[ -z "${TMUX:-}" ]]; then
    echo "Error: tmux内で実行してください" >&2
    exit 1
fi

CWD="$(pwd)"
CD_SPECIFIED=false

# Parse options
while [[ $# -gt 0 ]]; do
    case "$1" in
        --cd)
            [[ -z "${2:-}" ]] && { echo "Error: --cd にディレクトリを指定してください" >&2; exit 1; }
            CWD="$2"
            CD_SPECIFIED=true
            shift 2
            ;;
        *)
            break
            ;;
    esac
done

# --cd 指定時のみチルダ展開・正規化・存在チェックを実行
if $CD_SPECIFIED; then
    CWD="${CWD/#\~/$HOME}"
    CWD="$(realpath -m "$CWD")"
    if [[ ! -d "$CWD" ]]; then
        echo "Error: ディレクトリが存在しません: $CWD" >&2
        exit 1
    fi
fi

WINDOW_NAME="spawn-$(date +%H%M%S)-$$"

# Build launcher script to avoid shell quoting issues with tmux
# tmux new-window passes command to sh -c, which breaks multi-level quoting.
# Writing a temp script ensures arguments are preserved exactly.
LAUNCHER=$(mktemp /tmp/cld-spawn-XXXXXX.sh)
chmod +x "$LAUNCHER"

{
    echo '#!/bin/bash'
    echo "cd $(printf '%q' "$CWD") || exit 1"
    # CLD_PATH: テスト時のスタブ差し替え用（本番では未設定 → $SCRIPT_DIR/cld）
    printf '%q ' "${CLD_PATH:-$SCRIPT_DIR/cld}"
    if [[ $# -gt 0 ]]; then
        printf '%q ' "$@"
    fi
    printf '\n'
    # Keep window open on error for diagnosis
    cat <<'TRAP'
EXIT_CODE=$?
if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "=== claude exited with code $EXIT_CODE ==="
    echo "Press Enter to close, or Ctrl-C to keep open."
    read -r || sleep 60
fi
TRAP
} > "$LAUNCHER"

tmux new-window -n "$WINDOW_NAME" "bash '$LAUNCHER'; rm -f '$LAUNCHER'"

# Verify window was created
sleep 0.5
if tmux list-windows -F '#{window_name}' | grep -qF "$WINDOW_NAME"; then
    echo "spawned → tmux window '$WINDOW_NAME'"
else
    rm -f "$LAUNCHER"
    echo "Error: tmux window の作成に失敗しました" >&2
    exit 1
fi
