#!/bin/bash
# cld-fork - Fork current Claude Code session in a new tmux window
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
# shellcheck source=./session-name.sh
source "$SCRIPT_DIR/session-name.sh"

# tmux check
if [[ -z "${TMUX:-}" ]]; then
    echo "Error: tmux内で実行してください" >&2
    exit 1
fi

CWD="$(pwd)"
# 意味論的命名（失敗時は時刻ベースにフォールバック）
if ! WINDOW_NAME=$(generate_window_name fk "$CWD" "$CWD" 2>/dev/null); then
    WINDOW_NAME="fk-$(date +%H%M%S)-$$"
fi

# Build launcher script to avoid shell quoting issues with tmux
# tmux new-window passes command to sh -c, which breaks multi-level quoting.
# Writing a temp script ensures arguments are preserved exactly.
LAUNCHER=$(mktemp /tmp/cld-fork-XXXXXX.sh)
chmod +x "$LAUNCHER"

{
    echo '#!/bin/bash'
    echo "cd $(printf '%q' "$CWD") || exit 1"
    printf '%q ' "${CLD_PATH:-$SCRIPT_DIR/cld}" --continue --fork-session
    if [[ $# -gt 0 ]]; then
        printf '%q ' "$@"
    fi
    printf '\n'
    # Keep window open on error for diagnosis
    cat <<'TRAP'
EXIT_CODE=$?
if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "=== claude exited with code $EXIT_CODE ==="
    echo "Press Enter to close, or Ctrl-C to keep open."
    read -r || sleep 60
fi
TRAP
} > "$LAUNCHER"

tmux new-window -n "$WINDOW_NAME" "bash '$LAUNCHER'; rm -f '$LAUNCHER'"

# Verify window was created
sleep 0.5
if tmux list-windows -F '#{window_name}' | grep -qF "$WINDOW_NAME"; then
    echo "forked → tmux window '$WINDOW_NAME'"
else
    rm -f "$LAUNCHER"
    echo "Error: tmux window の作成に失敗しました" >&2
    exit 1
fi

# --- window-manifest 書き出し (Phase 2 / #290) ---
# shellcheck source=./window-manifest.sh
source "$SCRIPT_DIR/window-manifest.sh" 2>/dev/null || true
if declare -f manifest_append_entry > /dev/null 2>&1; then
    _WM_SESSION=$(tmux display-message -p '#{session_name}' 2>/dev/null || echo "main")
    _WM_INDEX=$(tmux list-windows -F '#{window_name} #{window_index}' 2>/dev/null \
        | awk -v n="$WINDOW_NAME" '$1==n {print $2; exit}')
    manifest_append_entry "$WINDOW_NAME" "$_WM_SESSION" "${_WM_INDEX:-0}" \
        "$CWD" "$CWD" "fk" 2>/dev/null || true
    # kill 時の tombstone hook
    _WM_SCRIPT=$(printf '%q' "$SCRIPT_DIR/window-manifest.sh")
    _WM_WINNAME=$(printf '%q' "$WINDOW_NAME")
    tmux set-hook -t "$WINDOW_NAME" pane-died \
        "run-shell 'bash $_WM_SCRIPT tombstone $_WM_WINNAME'" 2>/dev/null || true
    # rename 時の tombstone hook（旧 window_name をマークする）
    tmux set-hook -t "$WINDOW_NAME" window-renamed \
        "run-shell 'bash $_WM_SCRIPT tombstone $_WM_WINNAME'" 2>/dev/null || true
fi
