#!/bin/bash
# cld-observe-loop - 定期監視モード（複数ウィンドウを指定間隔でポーリング）
# Usage: cld-observe-loop [TARGET|--pattern GLOB] [--interval SECONDS] [--max-cycles N] [--notify-dir DIR]
set -euo pipefail

if [[ -n "${_TEST_MODE:-}" ]] && [[ -n "${CLD_OBSERVE_LOOP_SCRIPT_DIR:-}" ]]; then
    SCRIPT_DIR="$CLD_OBSERVE_LOOP_SCRIPT_DIR"
else
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
fi

DEFAULT_INTERVAL=300
DEFAULT_MAX_CYCLES=0
DEFAULT_NOTIFY_DIR="/tmp/claude-notifications"

# --- 引数解析 ---
TARGET=""
PATTERN=""
INTERVAL=$DEFAULT_INTERVAL
MAX_CYCLES=$DEFAULT_MAX_CYCLES
NOTIFY_DIR=$DEFAULT_NOTIFY_DIR

while [[ $# -gt 0 ]]; do
    case "$1" in
        --pattern)
            if [[ -z "${2:-}" ]]; then
                echo "Error: --pattern requires a value" >&2
                exit 1
            fi
            PATTERN="$2"
            shift 2
            ;;
        --interval)
            if [[ -z "${2:-}" ]]; then
                echo "Error: --interval requires a value" >&2
                exit 1
            fi
            INTERVAL="$2"
            if ! [[ "$INTERVAL" =~ ^[1-9][0-9]*$ ]]; then
                echo "Error: --interval requires a positive integer" >&2
                exit 1
            fi
            shift 2
            ;;
        --max-cycles)
            if [[ -z "${2:-}" ]]; then
                echo "Error: --max-cycles requires a value" >&2
                exit 1
            fi
            MAX_CYCLES="$2"
            if ! [[ "$MAX_CYCLES" =~ ^[0-9]+$ ]]; then
                echo "Error: --max-cycles requires a non-negative integer" >&2
                exit 1
            fi
            shift 2
            ;;
        --notify-dir)
            if [[ -z "${2:-}" ]]; then
                echo "Error: --notify-dir requires a value" >&2
                exit 1
            fi
            NOTIFY_DIR="$2"
            shift 2
            ;;
        -h|--help)
            cat <<'EOF'
Usage: cld-observe-loop [TARGET|--pattern GLOB] [--interval SECONDS] [--max-cycles N] [--notify-dir DIR]

Options:
  TARGET          単一ウィンドウ名（--pattern と排他）
  --pattern GLOB  window_name フィールドに対して bash glob でフィルタ（毎サイクル再検出）
  --interval N    ポーリング間隔（秒、デフォルト: 300）
  --max-cycles N  最大サイクル数（0 = 無制限、デフォルト: 0）
  --notify-dir D  通知ファイルディレクトリ（デフォルト: /tmp/claude-notifications）
EOF
            exit 0
            ;;
        -*)
            echo "Error: unknown option '$1'" >&2
            exit 1
            ;;
        *)
            if [[ -z "$TARGET" ]]; then
                TARGET="$1"
            else
                echo "Error: unexpected argument '$1'" >&2
                exit 1
            fi
            shift
            ;;
    esac
done

# TARGET と --pattern は排他
if [[ -n "$TARGET" ]] && [[ -n "$PATTERN" ]]; then
    echo "Error: TARGET と --pattern は同時に指定できません" >&2
    exit 1
fi

# どちらか必須
if [[ -z "$TARGET" ]] && [[ -z "$PATTERN" ]]; then
    echo "Error: TARGET または --pattern を指定してください" >&2
    echo "Usage: cld-observe-loop [TARGET|--pattern GLOB] [--interval SECONDS] [--max-cycles N] [--notify-dir DIR]" >&2
    exit 1
fi

# --- クリーンアップ ---
TMPFILES=()
cleanup() {
    for f in "${TMPFILES[@]:-}"; do
        rm -f "$f" 2>/dev/null || true
    done
}
trap cleanup EXIT
trap 'echo ""; echo "[cld-observe-loop] SIGINT/SIGTERM 受信 → 終了"; cleanup; exit 0' INT TERM

# --- 対象窓リスト取得 ---
get_target_windows() {
    if [[ -n "$TARGET" ]]; then
        echo "$TARGET"
        return
    fi
    # --pattern: session-state.sh list --json の window_name でフィルタ
    local list_json
    list_json=$("$SCRIPT_DIR/session-state.sh" list --json 2>/dev/null) || {
        echo ""
        return
    }
    echo "$list_json" | jq -r --arg pat "$PATTERN" \
        '.[] | select(.window_name | test($pat; "")) | .window_name' 2>/dev/null || true
}

# --- 通知ファイル確認（seen != true の attention を検知） ---
check_notifications() {
    local window_name="$1"
    [[ -d "$NOTIFY_DIR" ]] || return 0

    local found=false
    local notify_file
    while IFS= read -r notify_file; do
        [[ -f "$notify_file" ]] || continue
        local content
        content=$(cat "$notify_file" 2>/dev/null) || continue
        # state == "attention" かつ seen != true（null・未定義・false 含む）
        local state seen
        state=$(echo "$content" | jq -r '.state // empty' 2>/dev/null) || continue
        [[ "$state" == "attention" ]] || continue
        seen=$(echo "$content" | jq -r '.seen // "null"' 2>/dev/null) || continue
        if [[ "$seen" != "true" ]]; then
            found=true
            echo "[NOTIFY] $notify_file: state=attention seen=$seen"
            echo "$content"
        fi
    done < <(find "$NOTIFY_DIR" -maxdepth 1 -name "${window_name}:*.json" -o -name "*:*.json" 2>/dev/null \
        | grep -E "(^|/)${window_name}:[^/]+\.json$" 2>/dev/null || true)

    $found
}

# --- メインループ ---
CYCLE=0
echo "[cld-observe-loop] 開始 (interval=${INTERVAL}s, max_cycles=${MAX_CYCLES}, notify_dir=${NOTIFY_DIR})"
if [[ -n "$TARGET" ]]; then
    echo "[cld-observe-loop] 対象: $TARGET"
else
    echo "[cld-observe-loop] パターン: $PATTERN"
fi

while true; do
    CYCLE=$((CYCLE + 1))
    echo ""
    echo "[cld-observe-loop] === サイクル $CYCLE ==="

    # 対象窓リスト取得
    WINDOWS=()
    while IFS= read -r w; do
        [[ -n "$w" ]] && WINDOWS+=("$w")
    done < <(get_target_windows)

    # TARGET 単体の場合: 存在しなければエラー終了（初回のみ）
    if [[ -n "$TARGET" ]] && [[ ${#WINDOWS[@]} -eq 0 ]]; then
        if [[ $CYCLE -eq 1 ]]; then
            echo "Error: ウィンドウ '$TARGET' が見つかりません" >&2
            exit 1
        fi
    fi

    # 全窓消失チェック
    if [[ ${#WINDOWS[@]} -eq 0 ]]; then
        echo "[cld-observe-loop] 対象窓が全て消失 → 終了"
        break
    fi

    # 各窓の状態確認・異常検知
    ANOMALY_FOUND=false
    for win in "${WINDOWS[@]}"; do
        # 状態取得
        STATE=$("$SCRIPT_DIR/session-state.sh" state "$win" 2>/dev/null) || STATE="unknown"

        case "$STATE" in
            exited|error)
                ANOMALY_FOUND=true
                echo "[ANOMALY] $win: state=$STATE"
                # キャプチャ
                CAPFILE=$(mktemp /tmp/cld-observe-loop-cap-XXXXXX)
                TMPFILES+=("$CAPFILE")
                "$SCRIPT_DIR/session-comm.sh" capture "$win" --lines 50 >"$CAPFILE" 2>/dev/null || true
                echo "--- capture: $win ---"
                cat "$CAPFILE"
                echo "--- end capture ---"
                ;;
            attention)
                ANOMALY_FOUND=true
                echo "[ANOMALY] $win: state=$STATE"
                CAPFILE=$(mktemp /tmp/cld-observe-loop-cap-XXXXXX)
                TMPFILES+=("$CAPFILE")
                "$SCRIPT_DIR/session-comm.sh" capture "$win" --lines 50 >"$CAPFILE" 2>/dev/null || true
                echo "--- capture: $win ---"
                cat "$CAPFILE"
                echo "--- end capture ---"
                ;;
            *)
                echo "[OK] $win: state=$STATE"
                ;;
        esac

        # 通知ファイル確認
        if check_notifications "$win" 2>/dev/null; then
            ANOMALY_FOUND=true
            CAPFILE=$(mktemp /tmp/cld-observe-loop-cap-XXXXXX)
            TMPFILES+=("$CAPFILE")
            "$SCRIPT_DIR/session-comm.sh" capture "$win" --lines 50 >"$CAPFILE" 2>/dev/null || true
            echo "--- capture (notify): $win ---"
            cat "$CAPFILE"
            echo "--- end capture ---"
        fi
    done

    # max-cycles チェック
    if [[ $MAX_CYCLES -gt 0 ]] && [[ $CYCLE -ge $MAX_CYCLES ]]; then
        echo "[cld-observe-loop] max-cycles ($MAX_CYCLES) に到達 → 終了"
        break
    fi

    echo "[cld-observe-loop] ${INTERVAL}秒 待機..."
    sleep "$INTERVAL"
done

echo "[cld-observe-loop] 終了 (cycles=$CYCLE)"
