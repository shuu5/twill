digraph Dependencies {
    // Graph settings
    rankdir=LR;
    ranksep=0.8;
    nodesep=0.3;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10];
    edge [fontname="Helvetica", fontsize=9];
    label="workflow-test-ready";
    labelloc=t;
    fontsize=14;

    // L0: Controller Skills

    // L0: Launchers

    // L0.5: Workflow Skills
    skill_workflow_test_ready [label="dev:workflow-test-ready\n(260 tok)", shape=ellipse, style=filled, fillcolor="#e8f5e9"];

    // Reference Skills

    // L1: Direct Commands
    cmd_opsx_apply [label="opsx-apply\n(298 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_test_scaffold [label="test-scaffold\n(718 tok)", shape=box, style=filled, fillcolor="#bbdefb"];

    // L2: Sub Commands

    // L3: Agents

    // L3.5: Scripts

    // L4: External

    // Layer constraints
    { rank=same; skill_workflow_test_ready; }
    { rank=same; cmd_opsx_apply; cmd_test_scaffold; }

    // Edges
    skill_workflow_test_ready -> cmd_test_scaffold;
    skill_workflow_test_ready -> cmd_opsx_apply;

    // Ordering constraints (invisible edges)
    cmd_test_scaffold -> cmd_opsx_apply [style=invis, weight=10];

}