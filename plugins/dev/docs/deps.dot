    { rank=same; skill_co_autopilot; skill_co_issue; skill_co_project; skill_co_architect; }
    { rank=same; skill_workflow_setup; skill_workflow_test_ready; skill_workflow_pr_cycle; skill_workflow_dead_cleanup; skill_workflow_tech_debt_triage; }
    { rank=same; cmd_issue_assess; cmd_plugin_phase_diagnose; cmd_plugin_phase_verify; cmd_phase_review; cmd_fix_phase; cmd_e2e_screening; cmd_merge_gate; }
    { rank=same; cmd_self_improve_review; cmd_worktree_list; cmd_opsx_apply; cmd_opsx_archive; cmd_ac_verify; cmd_propose; cmd_apply; cmd_archive; cmd_check; cmd_loom_validate; }
    { rank=same; script_state_read; script_state_write; script_autopilot_init; script_session_create; script_session_archive; script_session_add_warning; script_worktree_delete; script_crash_detect; script_tech_stack_detect; script_specialist_output_parse; }

