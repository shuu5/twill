digraph Dependencies {
    // Graph settings
    rankdir=LR;
    ranksep=0.8;
    nodesep=0.3;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10];
    edge [fontname="Helvetica", fontsize=9];
    label="workflow-setup";
    labelloc=t;
    fontsize=14;

    // L0: Controller Skills

    // L0: Launchers

    // L0.5: Workflow Skills
    skill_workflow_setup [label="dev:workflow-setup\n(1,979 tok)", shape=ellipse, style=filled, fillcolor="#e8f5e9"];

    // Reference Skills

    // L1: Direct Commands
    cmd_init [label="init\n(621 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_worktree_create [label="worktree-create\n(461 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_project_board_status_update [label="project-board-status-update\n(1,203 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_crg_auto_build [label="crg-auto-build\n(312 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_opsx_propose [label="opsx-propose\n(406 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_ac_extract [label="ac-extract\n(366 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];

    // L2: Sub Commands

    // L3: Agents

    // L3.5: Scripts
    script_worktree_create [label="worktree-create\n(2,126 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_parse_issue_ac [label="parse-issue-ac\n(1,224 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];

    // L4: External

    // Layer constraints
    { rank=same; skill_workflow_setup; }
    { rank=same; cmd_init; cmd_worktree_create; cmd_project_board_status_update; cmd_crg_auto_build; cmd_opsx_propose; cmd_ac_extract; }
    { rank=same; script_worktree_create; script_parse_issue_ac; }

    // Edges
    skill_workflow_setup -> cmd_init;
    skill_workflow_setup -> cmd_worktree_create;
    skill_workflow_setup -> cmd_project_board_status_update;
    skill_workflow_setup -> cmd_crg_auto_build;
    skill_workflow_setup -> cmd_opsx_propose;
    skill_workflow_setup -> cmd_ac_extract;
    cmd_worktree_create -> script_worktree_create;
    cmd_ac_extract -> script_parse_issue_ac;

    // Ordering constraints (invisible edges)
    cmd_init -> cmd_worktree_create [style=invis, weight=10];
    cmd_worktree_create -> cmd_project_board_status_update [style=invis, weight=10];
    cmd_project_board_status_update -> cmd_crg_auto_build [style=invis, weight=10];
    cmd_crg_auto_build -> cmd_opsx_propose [style=invis, weight=10];
    cmd_opsx_propose -> cmd_ac_extract [style=invis, weight=10];

}