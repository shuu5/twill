digraph Dependencies {
    // Graph settings
    rankdir=LR;
    ranksep=0.8;
    nodesep=0.3;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10];
    edge [fontname="Helvetica", fontsize=9];
    label="workflow-test-ready";
    labelloc=t;
    fontsize=14;

    // L0: Controller Skills

    // L0: Launchers

    // L0.5: Workflow Skills
    skill_workflow_test_ready [label="twl:workflow-test-ready\n(745 tok)", shape=ellipse, style=filled, fillcolor="#e8f5e9"];

    // Reference Skills
    skill_ref_specialist_output_schema [label="twl:ref-specialist-output-schema\n(1,283 tok)", shape=note, style=filled, fillcolor="#e1f5fe"];

    // L1: Direct Commands
    cmd_check [label="check\n(842 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_e2e_plan [label="e2e-plan\n(456 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_test_scaffold [label="test-scaffold\n(684 tok)", shape=box, style=filled, fillcolor="#bbdefb"];

    // L2: Sub Commands

    // L3: Agents
    agent_e2e_generate [label="e2e-generate\n(1,317 tok)", shape=ellipse, style=filled, fillcolor="#ede7f6"];

    // L3.5: Scripts
    script_state_read [label="state-read\n(5,796 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_state_write [label="state-write\n(5,796 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_chain_runner [label="chain-runner\n(10,470 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_worker_terminal_guard [label="worker-terminal-guard\n(770 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_worktree_create [label="worktree-create\n(6,686 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_autopilot_github [label="autopilot-github\n(3,666 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_chain_steps [label="chain-steps\n(10,470 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_compaction_resume [label="compaction-resume\n(1,030 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_resolve_issue_num [label="resolve-issue-num\n(716 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];

    // L4: External

    // Layer constraints
    { rank=same; skill_workflow_test_ready; }
    { rank=same; skill_ref_specialist_output_schema; }
    { rank=same; cmd_check; cmd_e2e_plan; cmd_test_scaffold; }
    { rank=same; agent_e2e_generate; }
    { rank=same; script_state_read; script_state_write; script_chain_runner; script_worker_terminal_guard; script_worktree_create; script_autopilot_github; script_chain_steps; script_compaction_resume; script_resolve_issue_num; }

    // Edges
    skill_workflow_test_ready -> cmd_test_scaffold;
    skill_workflow_test_ready -> cmd_check;
    skill_workflow_test_ready -> cmd_e2e_plan;
    skill_workflow_test_ready -> script_chain_runner;
    skill_workflow_test_ready -> script_compaction_resume;
    cmd_test_scaffold -> agent_e2e_generate [style=dashed];
    cmd_test_scaffold -> skill_ref_specialist_output_schema;
    agent_e2e_generate -> skill_ref_specialist_output_schema [style=dotted];

    // Ordering constraints (invisible edges)
    script_chain_runner -> script_compaction_resume [style=invis, weight=10];
    cmd_test_scaffold -> cmd_check [style=invis, weight=10];
    cmd_check -> cmd_e2e_plan [style=invis, weight=10];
    cmd_e2e_plan -> script_chain_runner [style=invis, weight=10];
    script_chain_runner -> script_compaction_resume [style=invis, weight=10];
    script_chain_runner -> script_compaction_resume [style=invis, weight=10];
    script_chain_runner -> script_compaction_resume [style=invis, weight=10];
    agent_e2e_generate -> skill_ref_specialist_output_schema [style=invis, weight=10];
    script_state_read -> script_state_write [style=invis, weight=10];
    script_state_read -> script_state_write [style=invis, weight=10];
    script_state_read -> script_state_write [style=invis, weight=10];
    script_state_read -> script_state_write [style=invis, weight=10];

}