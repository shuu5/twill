digraph Dependencies {
    // Graph settings
    rankdir=LR;
    ranksep=0.8;
    nodesep=0.3;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10];
    edge [fontname="Helvetica", fontsize=9];
    label="workflow-test-ready";
    labelloc=t;
    fontsize=14;

    // L0: Controller Skills

    // L0: Launchers

    // L0.5: Workflow Skills
    skill_workflow_test_ready [label="twl:workflow-test-ready\n(2,098 tok)", shape=ellipse, style=filled, fillcolor="#e8f5e9"];

    // Reference Skills
    skill_ref_specialist_output_schema [label="twl:ref-specialist-output-schema\n(2,563 tok)", shape=note, style=filled, fillcolor="#e1f5fe"];

    // L1: Direct Commands
    cmd_change_apply [label="change-apply\n(857 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_check [label="check\n(1,949 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_e2e_plan [label="e2e-plan\n(435 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_test_scaffold [label="test-scaffold\n(718 tok)", shape=box, style=filled, fillcolor="#bbdefb"];

    // L2: Sub Commands

    // L3: Agents
    agent_spec_scaffold_tests [label="spec-scaffold-tests\n(1,761 tok)", shape=ellipse, style=filled, fillcolor="#ede7f6"];
    agent_e2e_generate [label="e2e-generate\n(2,028 tok)", shape=ellipse, style=filled, fillcolor="#ede7f6"];

    // L3.5: Scripts
    script_state_read [label="state-read\n(986 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_state_write [label="state-write\n(2,571 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_resolve_project [label="resolve-project\n(929 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_chain_runner [label="chain-runner\n(6,274 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_worktree_create [label="worktree-create\n(2,126 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_parse_issue_ac [label="parse-issue-ac\n(1,224 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_chain_steps [label="chain-steps\n(230 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_compaction_resume [label="compaction-resume\n(1,009 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_resolve_issue_num [label="resolve-issue-num\n(716 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];

    // L4: External

    // Layer constraints
    { rank=same; skill_workflow_test_ready; }
    { rank=same; skill_ref_specialist_output_schema; }
    { rank=same; cmd_change_apply; cmd_check; cmd_e2e_plan; cmd_test_scaffold; }
    { rank=same; agent_spec_scaffold_tests; agent_e2e_generate; }
    { rank=same; script_state_read; script_state_write; script_resolve_project; script_chain_runner; script_worktree_create; script_parse_issue_ac; script_chain_steps; script_compaction_resume; script_resolve_issue_num; }

    // Edges
    skill_workflow_test_ready -> cmd_test_scaffold;
    skill_workflow_test_ready -> cmd_change_apply;
    skill_workflow_test_ready -> cmd_check;
    skill_workflow_test_ready -> cmd_e2e_plan;
    skill_workflow_test_ready -> script_chain_runner;
    skill_workflow_test_ready -> script_compaction_resume;
    cmd_test_scaffold -> agent_spec_scaffold_tests [style=dashed];
    cmd_test_scaffold -> agent_e2e_generate [style=dashed];
    cmd_test_scaffold -> skill_ref_specialist_output_schema;
    agent_spec_scaffold_tests -> skill_ref_specialist_output_schema [style=dotted];
    agent_e2e_generate -> skill_ref_specialist_output_schema [style=dotted];

    // Ordering constraints (invisible edges)
    script_chain_runner -> script_compaction_resume [style=invis, weight=10];
    cmd_test_scaffold -> cmd_change_apply [style=invis, weight=10];
    cmd_change_apply -> cmd_check [style=invis, weight=10];
    cmd_check -> cmd_e2e_plan [style=invis, weight=10];
    cmd_e2e_plan -> script_chain_runner [style=invis, weight=10];
    script_chain_runner -> script_compaction_resume [style=invis, weight=10];
    script_chain_runner -> script_compaction_resume [style=invis, weight=10];
    script_chain_runner -> script_compaction_resume [style=invis, weight=10];
    agent_spec_scaffold_tests -> agent_e2e_generate [style=invis, weight=10];
    agent_e2e_generate -> skill_ref_specialist_output_schema [style=invis, weight=10];
    script_state_read -> script_state_write [style=invis, weight=10];
    script_state_read -> script_state_write [style=invis, weight=10];
    script_state_read -> script_state_write [style=invis, weight=10];

}