    agent_worker_structure [label="worker-structure\n(1,244 tok)", shape=ellipse, style=filled, fillcolor="#ede7f6"];
    agent_worker_principles [label="worker-principles\n(1,154 tok)", shape=ellipse, style=filled, fillcolor="#ede7f6"];
    agent_worker_architecture [label="worker-architecture\n(1,695 tok)", shape=ellipse, style=filled, fillcolor="#ede7f6"];

    // L3.5: Scripts

    // L4: External

    // Layer constraints
    { rank=same; skill_workflow_plugin_diagnose; }
    { rank=same; skill_ref_specialist_output_schema; skill_ref_architecture; }
    { rank=same; cmd_plugin_migrate_analyze; cmd_plugin_diagnose; cmd_plugin_fix; cmd_plugin_verify; cmd_plugin_phase_diagnose; cmd_plugin_phase_verify; }
    { rank=same; agent_worker_structure; agent_worker_principles; agent_worker_architecture; }

    // Edges
    skill_workflow_plugin_diagnose -> cmd_plugin_migrate_analyze;
    skill_workflow_plugin_diagnose -> cmd_plugin_diagnose;
    skill_workflow_plugin_diagnose -> cmd_plugin_phase_diagnose;
    skill_workflow_plugin_diagnose -> cmd_plugin_fix;
    skill_workflow_plugin_diagnose -> cmd_plugin_verify;
    skill_workflow_plugin_diagnose -> cmd_plugin_phase_verify;
    cmd_plugin_phase_diagnose -> agent_worker_structure [style=dashed];
    cmd_plugin_phase_diagnose -> agent_worker_principles [style=dashed];
    cmd_plugin_phase_diagnose -> agent_worker_architecture [style=dashed];
    cmd_plugin_phase_diagnose -> skill_ref_specialist_output_schema;
    cmd_plugin_phase_diagnose -> skill_ref_architecture;
    cmd_plugin_phase_verify -> agent_worker_structure [style=dashed];
    cmd_plugin_phase_verify -> agent_worker_principles [style=dashed];
    cmd_plugin_phase_verify -> agent_worker_architecture [style=dashed];
    cmd_plugin_phase_verify -> skill_ref_specialist_output_schema;
    cmd_plugin_phase_verify -> skill_ref_architecture;
    agent_worker_structure -> skill_ref_specialist_output_schema [style=dotted];
    agent_worker_principles -> skill_ref_specialist_output_schema [style=dotted];
    agent_worker_architecture -> skill_ref_specialist_output_schema [style=dotted];
    agent_worker_architecture -> skill_ref_architecture [style=dotted];

    // Ordering constraints (invisible edges)
    cmd_plugin_migrate_analyze -> cmd_plugin_diagnose [style=invis, weight=10];
    cmd_plugin_diagnose -> cmd_plugin_phase_diagnose [style=invis, weight=10];
    cmd_plugin_phase_diagnose -> cmd_plugin_fix [style=invis, weight=10];
    cmd_plugin_fix -> cmd_plugin_verify [style=invis, weight=10];
    cmd_plugin_verify -> cmd_plugin_phase_verify [style=invis, weight=10];
    agent_worker_structure -> agent_worker_principles [style=invis, weight=10];
    agent_worker_principles -> agent_worker_architecture [style=invis, weight=10];
    agent_worker_architecture -> skill_ref_specialist_output_schema [style=invis, weight=10];
    skill_ref_specialist_output_schema -> skill_ref_architecture [style=invis, weight=10];
    agent_worker_structure -> agent_worker_principles [style=invis, weight=10];
    agent_worker_principles -> agent_worker_architecture [style=invis, weight=10];
    agent_worker_architecture -> skill_ref_specialist_output_schema [style=invis, weight=10];
    skill_ref_specialist_output_schema -> skill_ref_architecture [style=invis, weight=10];
