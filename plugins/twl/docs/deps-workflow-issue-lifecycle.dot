digraph Dependencies {
    // Graph settings
    rankdir=LR;
    ranksep=0.8;
    nodesep=0.3;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10];
    edge [fontname="Helvetica", fontsize=9];
    label="workflow-issue-lifecycle";
    labelloc=t;
    fontsize=14;

    // L0: Controller Skills

    // L0: Launchers

    // L0.5: Workflow Skills
    skill_workflow_issue_lifecycle [label="twl:workflow-issue-lifecycle\n(481 tok)", shape=ellipse, style=filled, fillcolor="#e8f5e9"];

    // Reference Skills
    skill_lifecycle_processing_flow [label="twl:lifecycle-processing-flow\n(2,325 tok)", shape=note, style=filled, fillcolor="#e1f5fe"];

    // L1: Direct Commands
    cmd_issue_structure [label="issue-structure\n(1,406 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_issue_create [label="issue-create\n(1,440 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_issue_spec_review [label="issue-spec-review\n(1,870 tok)", shape=box, style=filled, fillcolor="#bbdefb"];
    cmd_issue_review_aggregate [label="issue-review-aggregate\n(1,503 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_issue_arch_drift [label="issue-arch-drift\n(1,079 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_project_board_sync [label="project-board-sync\n(1,184 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];

    // L2: Sub Commands

    // L3: Agents
    agent_issue_critic [label="issue-critic\n(1,268 tok)", shape=ellipse, style=filled, fillcolor="#ede7f6"];
    agent_issue_feasibility [label="issue-feasibility\n(1,175 tok)", shape=ellipse, style=filled, fillcolor="#ede7f6"];
    agent_worker_codex_reviewer [label="worker-codex-reviewer\n(2,121 tok)", shape=ellipse, style=filled, fillcolor="#ede7f6"];

    // L3.5: Scripts
    script_escape_issue_body [label="escape-issue-body\n(63 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_spec_review_manifest [label="spec-review-manifest\n(169 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_spec_review_session_init [label="spec-review-session-init\n(501 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];

    // L4: External

    // Layer constraints
    { rank=same; skill_workflow_issue_lifecycle; }
    { rank=same; skill_lifecycle_processing_flow; }
    { rank=same; cmd_issue_structure; cmd_issue_create; cmd_issue_spec_review; cmd_issue_review_aggregate; cmd_issue_arch_drift; cmd_project_board_sync; }
    { rank=same; agent_issue_critic; agent_issue_feasibility; agent_worker_codex_reviewer; }
    { rank=same; script_escape_issue_body; script_spec_review_manifest; script_spec_review_session_init; }

    // Edges
    skill_workflow_issue_lifecycle -> cmd_issue_structure;
    skill_workflow_issue_lifecycle -> cmd_issue_spec_review;
    skill_workflow_issue_lifecycle -> cmd_issue_review_aggregate;
    skill_workflow_issue_lifecycle -> cmd_issue_arch_drift;
    skill_workflow_issue_lifecycle -> cmd_issue_create;
    skill_workflow_issue_lifecycle -> cmd_project_board_sync;
    skill_workflow_issue_lifecycle -> script_spec_review_session_init;
    skill_workflow_issue_lifecycle -> skill_lifecycle_processing_flow;
    cmd_issue_spec_review -> agent_issue_critic [style=dashed];
    cmd_issue_spec_review -> agent_issue_feasibility [style=dashed];
    cmd_issue_spec_review -> agent_worker_codex_reviewer [style=dashed];
    cmd_issue_spec_review -> script_escape_issue_body;
    cmd_issue_spec_review -> script_spec_review_manifest;

    // Ordering constraints (invisible edges)
    cmd_issue_structure -> cmd_issue_spec_review [style=invis, weight=10];
    cmd_issue_spec_review -> cmd_issue_review_aggregate [style=invis, weight=10];
    cmd_issue_review_aggregate -> cmd_issue_arch_drift [style=invis, weight=10];
    cmd_issue_arch_drift -> cmd_issue_create [style=invis, weight=10];
    cmd_issue_create -> cmd_project_board_sync [style=invis, weight=10];
    cmd_project_board_sync -> script_spec_review_session_init [style=invis, weight=10];
    script_spec_review_session_init -> skill_lifecycle_processing_flow [style=invis, weight=10];
    cmd_issue_spec_review -> cmd_issue_review_aggregate [style=invis, weight=10];
    cmd_issue_review_aggregate -> cmd_issue_arch_drift [style=invis, weight=10];
    cmd_issue_arch_drift -> script_spec_review_session_init [style=invis, weight=10];
    agent_issue_critic -> agent_issue_feasibility [style=invis, weight=10];
    agent_issue_feasibility -> agent_worker_codex_reviewer [style=invis, weight=10];
    agent_worker_codex_reviewer -> script_escape_issue_body [style=invis, weight=10];
    script_escape_issue_body -> script_spec_review_manifest [style=invis, weight=10];

}