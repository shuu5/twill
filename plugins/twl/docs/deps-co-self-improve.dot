digraph Dependencies {
    // Graph settings
    rankdir=LR;
    ranksep=0.8;
    nodesep=0.3;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10];
    edge [fontname="Helvetica", fontsize=9];
    label="co-self-improve";
    labelloc=t;
    fontsize=14;

    // L0: Controller Skills
    skill_co_self_improve [label="twl:co-self-improve\n(1,171 tok)", shape=ellipse, style=filled, fillcolor="#c8e6c9"];

    // L0: Launchers

    // L0.5: Workflow Skills
    skill_workflow_observe_loop [label="twl:workflow-observe-loop\n(1,151 tok)", shape=ellipse, style=filled, fillcolor="#e8f5e9"];

    // Reference Skills

    // L1: Direct Commands
    cmd_observe_once [label="observe-once\n(436 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_problem_detect [label="problem-detect\n(678 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_issue_draft_from_observation [label="issue-draft-from-observation\n(591 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_observe_and_detect [label="observe-and-detect\n(461 tok)", shape=box, style=filled, fillcolor="#bbdefb"];
    cmd_observe_retrospective [label="observe-retrospective\n(521 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_test_project_init [label="test-project-init\n(847 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_test_project_reset [label="test-project-reset\n(443 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_test_project_scenario_load [label="test-project-scenario-load\n(861 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];

    // L2: Sub Commands

    // L3: Agents

    // L3.5: Scripts
    script_observe_wrapper [label="observe-wrapper\n(122 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_session_state_wrapper [label="session-state-wrapper\n(126 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];

    // L4: External

    // Layer constraints
    { rank=same; skill_co_self_improve; }
    { rank=same; skill_workflow_observe_loop; }
    { rank=same; cmd_observe_once; cmd_problem_detect; cmd_issue_draft_from_observation; cmd_observe_and_detect; cmd_observe_retrospective; cmd_test_project_init; cmd_test_project_reset; cmd_test_project_scenario_load; }
    { rank=same; script_observe_wrapper; script_session_state_wrapper; }

    // Edges
    skill_co_self_improve -> skill_workflow_observe_loop;
    skill_co_self_improve -> cmd_test_project_init;
    skill_co_self_improve -> cmd_test_project_reset;
    skill_co_self_improve -> cmd_test_project_scenario_load;
    skill_co_self_improve -> cmd_observe_once;
    skill_co_self_improve -> cmd_problem_detect;
    skill_co_self_improve -> cmd_issue_draft_from_observation;
    skill_co_self_improve -> cmd_observe_retrospective;
    skill_co_self_improve -> agent_observer_evaluator [style=dashed];
    skill_co_self_improve -> skill_test_scenario_catalog;
    skill_co_self_improve -> skill_observation_pattern_catalog;
    skill_co_self_improve -> skill_load_test_baselines;
    skill_workflow_observe_loop -> cmd_observe_and_detect;
    skill_workflow_observe_loop -> cmd_observe_retrospective;
    cmd_observe_once -> script_observe_wrapper;
    cmd_observe_once -> script_session_state_wrapper;
    cmd_problem_detect -> skill_observation_pattern_catalog;
    cmd_observe_and_detect -> agent_observer_evaluator [style=dashed];

    // Ordering constraints (invisible edges)
    skill_workflow_observe_loop -> cmd_test_project_init [style=invis, weight=10];
    cmd_test_project_init -> cmd_test_project_reset [style=invis, weight=10];
    cmd_test_project_reset -> cmd_test_project_scenario_load [style=invis, weight=10];
    cmd_test_project_scenario_load -> cmd_observe_once [style=invis, weight=10];
    cmd_observe_once -> cmd_problem_detect [style=invis, weight=10];
    cmd_problem_detect -> cmd_issue_draft_from_observation [style=invis, weight=10];
    cmd_issue_draft_from_observation -> cmd_observe_retrospective [style=invis, weight=10];
    cmd_observe_retrospective -> agent_observer_evaluator [style=invis, weight=10];
    agent_observer_evaluator -> skill_test_scenario_catalog [style=invis, weight=10];
    skill_test_scenario_catalog -> skill_observation_pattern_catalog [style=invis, weight=10];
    skill_observation_pattern_catalog -> skill_load_test_baselines [style=invis, weight=10];
    cmd_observe_and_detect -> cmd_observe_retrospective [style=invis, weight=10];
    script_observe_wrapper -> script_session_state_wrapper [style=invis, weight=10];

}