digraph Dependencies {
    // Graph settings
    rankdir=LR;
    ranksep=0.8;
    nodesep=0.3;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10];
    edge [fontname="Helvetica", fontsize=9];
    label="co-utility";
    labelloc=t;
    fontsize=14;

    // L0: Controller Skills
    skill_co_utility [label="twl:co-utility\n(777 tok)", shape=ellipse, style=filled, fillcolor="#c8e6c9"];

    // L0: Launchers

    // L0.5: Workflow Skills

    // Reference Skills

    // L1: Direct Commands
    cmd_worktree_list [label="worktree-list\n(200 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_twl_validate [label="twl-validate\n(886 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_services [label="services\n(967 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_ui_capture [label="ui-capture\n(637 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_worktree_delete [label="worktree-delete\n(408 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_schema_update [label="schema-update\n(498 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];

    // L2: Sub Commands

    // L3: Agents

    // L3.5: Scripts
    script_worktree_delete [label="worktree-delete\n(1,153 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];

    // L4: External

    // Layer constraints
    { rank=same; skill_co_utility; }
    { rank=same; cmd_worktree_list; cmd_twl_validate; cmd_services; cmd_ui_capture; cmd_worktree_delete; cmd_schema_update; }
    { rank=same; script_worktree_delete; }

    // Edges
    skill_co_utility -> cmd_worktree_list;
    skill_co_utility -> cmd_worktree_delete;
    skill_co_utility -> cmd_twl_validate;
    skill_co_utility -> cmd_services;
    skill_co_utility -> cmd_ui_capture;
    skill_co_utility -> cmd_schema_update;
    cmd_worktree_delete -> script_worktree_delete;

    // Ordering constraints (invisible edges)
    cmd_worktree_list -> cmd_worktree_delete [style=invis, weight=10];
    cmd_worktree_delete -> cmd_twl_validate [style=invis, weight=10];
    cmd_twl_validate -> cmd_services [style=invis, weight=10];
    cmd_services -> cmd_ui_capture [style=invis, weight=10];
    cmd_ui_capture -> cmd_schema_update [style=invis, weight=10];

}