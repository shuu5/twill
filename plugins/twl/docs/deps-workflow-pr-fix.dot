digraph Dependencies {
    // Graph settings
    rankdir=LR;
    ranksep=0.8;
    nodesep=0.3;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10];
    edge [fontname="Helvetica", fontsize=9];
    label="workflow-pr-fix";
    labelloc=t;
    fontsize=14;

    // L0: Controller Skills

    // L0: Launchers

    // L0.5: Workflow Skills
    skill_workflow_pr_fix [label="twl:workflow-pr-fix\n(863 tok)", shape=ellipse, style=filled, fillcolor="#e8f5e9"];

    // Reference Skills

    // L1: Direct Commands
    cmd_post_fix_verify [label="post-fix-verify\n(353 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_warning_fix [label="warning-fix\n(363 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_fix_phase [label="fix-phase\n(532 tok)", shape=box, style=filled, fillcolor="#bbdefb"];
    cmd_spec_diagnose [label="spec-diagnose\n(634 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];

    // L2: Sub Commands

    // L3: Agents

    // L3.5: Scripts
    script_checkpoint_read [label="checkpoint-read\n(2,418 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];

    // L4: External

    // Layer constraints
    { rank=same; skill_workflow_pr_fix; }
    { rank=same; cmd_post_fix_verify; cmd_warning_fix; cmd_fix_phase; cmd_spec_diagnose; }
    { rank=same; script_checkpoint_read; }

    // Edges
    skill_workflow_pr_fix -> cmd_fix_phase;
    skill_workflow_pr_fix -> cmd_post_fix_verify;
    skill_workflow_pr_fix -> cmd_warning_fix;
    skill_workflow_pr_fix -> cmd_spec_diagnose;
    cmd_fix_phase -> script_checkpoint_read;

    // Ordering constraints (invisible edges)
    cmd_fix_phase -> cmd_post_fix_verify [style=invis, weight=10];
    cmd_post_fix_verify -> cmd_warning_fix [style=invis, weight=10];
    cmd_warning_fix -> cmd_spec_diagnose [style=invis, weight=10];

}