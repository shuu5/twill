digraph Dependencies {
    // Graph settings
    rankdir=LR;
    ranksep=0.8;
    nodesep=0.3;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10];
    edge [fontname="Helvetica", fontsize=9];
    label="workflow-pr-fix";
    labelloc=t;
    fontsize=14;

    // L0: Controller Skills

    // L0: Launchers

    // L0.5: Workflow Skills
    skill_workflow_pr_fix [label="twl:workflow-pr-fix\n(1,567 tok)", shape=ellipse, style=filled, fillcolor="#e8f5e9"];

    // Reference Skills

    // L1: Direct Commands
    cmd_post_fix_verify [label="post-fix-verify\n(756 tok)", shape=box, style=filled, fillcolor="#bbdefb"];
    cmd_warning_fix [label="warning-fix\n(597 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];
    cmd_fix_phase [label="fix-phase\n(891 tok)", shape=box, style=filled, fillcolor="#bbdefb"];

    // L2: Sub Commands

    // L3: Agents
    agent_worker_codex_reviewer [label="worker-codex-reviewer\n(2,121 tok)", shape=ellipse, style=filled, fillcolor="#ede7f6"];
    agent_worker_code_reviewer [label="worker-code-reviewer\n(3,040 tok)", shape=ellipse, style=filled, fillcolor="#ede7f6"];
    agent_worker_security_reviewer [label="worker-security-reviewer\n(866 tok)", shape=ellipse, style=filled, fillcolor="#ede7f6"];

    // L3.5: Scripts
    script_tech_stack_detect [label="tech-stack-detect\n(845 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_autopilot_parser [label="autopilot-parser\n(2,484 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_resolve_issue_num [label="resolve-issue-num\n(716 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_pr_review_manifest [label="pr-review-manifest\n(2,131 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_checkpoint_read [label="checkpoint-read\n(3,254 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];

    // L4: External

    // Layer constraints
    { rank=same; skill_workflow_pr_fix; }
    { rank=same; cmd_post_fix_verify; cmd_warning_fix; cmd_fix_phase; }
    { rank=same; agent_worker_codex_reviewer; agent_worker_code_reviewer; agent_worker_security_reviewer; }
    { rank=same; script_tech_stack_detect; script_autopilot_parser; script_resolve_issue_num; script_pr_review_manifest; script_checkpoint_read; }

    // Edges
    skill_workflow_pr_fix -> cmd_fix_phase;
    skill_workflow_pr_fix -> cmd_post_fix_verify;
    skill_workflow_pr_fix -> cmd_warning_fix;
    cmd_post_fix_verify -> agent_worker_code_reviewer [style=dashed];
    cmd_post_fix_verify -> agent_worker_security_reviewer [style=dashed];
    cmd_post_fix_verify -> agent_worker_codex_reviewer [style=dashed];
    cmd_post_fix_verify -> script_pr_review_manifest;
    cmd_post_fix_verify -> script_autopilot_parser;
    cmd_fix_phase -> script_checkpoint_read;

    // Ordering constraints (invisible edges)
    cmd_fix_phase -> cmd_post_fix_verify [style=invis, weight=10];
    cmd_post_fix_verify -> cmd_warning_fix [style=invis, weight=10];
    agent_worker_code_reviewer -> agent_worker_security_reviewer [style=invis, weight=10];
    agent_worker_security_reviewer -> agent_worker_codex_reviewer [style=invis, weight=10];
    agent_worker_codex_reviewer -> script_pr_review_manifest [style=invis, weight=10];
    script_pr_review_manifest -> script_autopilot_parser [style=invis, weight=10];
    script_autopilot_parser -> script_tech_stack_detect [style=invis, weight=10];
    agent_worker_code_reviewer -> agent_worker_security_reviewer [style=invis, weight=10];
    script_pr_review_manifest -> script_autopilot_parser [style=invis, weight=10];
    script_autopilot_parser -> script_tech_stack_detect [style=invis, weight=10];
    agent_worker_code_reviewer -> agent_worker_security_reviewer [style=invis, weight=10];

}