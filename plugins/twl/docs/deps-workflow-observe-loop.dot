digraph Dependencies {
    // Graph settings
    rankdir=LR;
    ranksep=0.8;
    nodesep=0.3;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10];
    edge [fontname="Helvetica", fontsize=9];
    label="workflow-observe-loop";
    labelloc=t;
    fontsize=14;

    // L0: Controller Skills

    // L0: Launchers

    // L0.5: Workflow Skills
    skill_workflow_observe_loop [label="twl:workflow-observe-loop\n(1,503 tok)", shape=ellipse, style=filled, fillcolor="#e8f5e9"];

    // Reference Skills

    // L1: Direct Commands
    cmd_observe_and_detect [label="observe-and-detect\n(460 tok)", shape=box, style=filled, fillcolor="#bbdefb"];
    cmd_observe_retrospective [label="observe-retrospective\n(521 tok)", shape=box, style=filled, fillcolor="#e3f2fd"];

    // L2: Sub Commands

    // L3: Agents
    agent_observer_evaluator [label="observer-evaluator\n(1,469 tok)", shape=ellipse, style=filled, fillcolor="#ede7f6"];

    // L3.5: Scripts
    script_observe_wrapper [label="observe-wrapper\n(122 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];
    script_session_state_wrapper [label="session-state-wrapper\n(126 tok)", shape=hexagon, style=filled, fillcolor="#FF9800"];

    // L4: External

    // Layer constraints
    { rank=same; skill_workflow_observe_loop; }
    { rank=same; cmd_observe_and_detect; cmd_observe_retrospective; }
    { rank=same; agent_observer_evaluator; }
    { rank=same; script_observe_wrapper; script_session_state_wrapper; }

    // Edges
    skill_workflow_observe_loop -> cmd_observe_and_detect;
    skill_workflow_observe_loop -> cmd_observe_retrospective;
    skill_workflow_observe_loop -> script_observe_wrapper;
    skill_workflow_observe_loop -> script_session_state_wrapper;
    cmd_observe_and_detect -> agent_observer_evaluator [style=dashed];

    // Ordering constraints (invisible edges)
    cmd_observe_retrospective -> agent_observer_evaluator [style=invis, weight=10];
    cmd_observe_and_detect -> cmd_observe_retrospective [style=invis, weight=10];
    cmd_observe_retrospective -> script_observe_wrapper [style=invis, weight=10];
    script_observe_wrapper -> script_session_state_wrapper [style=invis, weight=10];
    script_observe_wrapper -> script_session_state_wrapper [style=invis, weight=10];

}