{
  "_comment_": "Phase 1 PoC C1 (2026-05-15、ADR-043 / Phase J 後): hook foundation。keep 5 (worktree-boundary / host-safety / deps-yaml-guard / pre-compact / post-compact) + new 3 (spec-write-boundary / phase-gate tier 1 / failure-learn Stage A)。drop 5 (ask-user-question / spec-review-gate / post-tool-use-validate / check-specialist-completeness / permission-request-auto-approve、autopilot 廃止 + gate-hook 置換)。旧 post-tool-use-bash-error.sh (.self-improve/errors.jsonl) は failure-learn Stage A に置換。廃止 6 hook の script 本体は scripts/hooks/ に archive で残存 (rollback path 確保のため、hooks.json.bak と整合)、Phase 3 cutover で物理削除予定。EXP-041 verify 待ち: 'if: Skill(phaser-*)' ワイルドカード動作の empirical verify (Phase 2 smoke 予定)。",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/pre-tool-use-worktree-boundary.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/pre-tool-use-host-safety.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(deps.yaml)|Write(deps.yaml)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/pre-tool-use-deps-yaml-guard.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/pre-tool-use-spec-write-boundary.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "if": "Skill(phaser-*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/pre-tool-use-phase-gate.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/post-tool-use-verify-coverage.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/post-tool-use-failure-learn.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/pre-compact-checkpoint.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/post-compact-checkpoint.sh",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
