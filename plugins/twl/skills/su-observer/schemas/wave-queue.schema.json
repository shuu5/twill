{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WaveQueue",
  "description": "Wave 候補キュー管理スキーマ (#1155)",
  "type": "object",
  "required": ["version", "current_wave", "queue"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "current_wave": {
      "type": "integer",
      "minimum": 0
    },
    "queue": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/WaveEntry"
      }
    }
  },
  "definitions": {
    "WaveEntry": {
      "type": "object",
      "required": ["wave", "issues", "spawn_cmd_argv", "depends_on_waves", "spawn_when"],
      "additionalProperties": false,
      "properties": {
        "wave": {
          "type": "integer",
          "minimum": 1
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "spawn_cmd_argv": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "shell 文字列ではなく argv 配列で保持（shell injection 防止）"
        },
        "depends_on_waves": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "spawn_when": {
          "type": "string",
          "enum": ["all_current_wave_idle_completed"]
        }
      }
    }
  }
}
