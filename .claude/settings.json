{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'case \"${TOOL_INPUT_file_path:-}\" in *architecture/domain/model.md|*architecture/domain/context-map.md) echo \"architecture domain ファイルの変更は co-architect 経由で行ってください\" >&2; exit 2;; esac'",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash plugins/twl/scripts/hooks/pre-bash-commit-validate.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash plugins/twl/scripts/hooks/pre-bash-refined-label-gate.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash plugins/twl/scripts/hooks/pre-bash-phase3-gate.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash plugins/twl/scripts/su-precompact.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash plugins/twl/scripts/su-postcompact.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash plugins/twl/scripts/su-session-compact.sh",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
