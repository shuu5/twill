#!/bin/bash
# loom - Loom framework CLI
# Wrapper around loom-engine.py (analyze-deps.py)
set -euo pipefail

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
ENGINE="$SCRIPT_DIR/loom-engine.py"

if [ ! -f "$ENGINE" ]; then
    echo "Error: loom-engine.py not found at $ENGINE" >&2
    exit 1
fi

show_help() {
    cat <<'EOF'
loom - Loom framework CLI

Usage: loom <command> [args]

Commands:
  check           ファイル存在チェック
  validate        型ルール検証 (can_spawn/spawnable_by)
  tree            ASCII ツリー出力
  orphans         未使用/孤立ノード検出
  complexity      7メトリクス複雑さレポート
  update-readme   SVG グラフ生成 + README.md 更新
  audit           Deep validation (controller bloat, ref placement, tools)
  deep-validate   audit のエイリアス
  reverse <name>  逆依存関係を表示
  target <name>   依存関係を表示
  update-svgs     全 plugin の SVG を一括再生成
  graph           Graphviz DOT 出力 (デフォルト)
  mermaid         Mermaid フローチャート出力
  tokens          トークン数を表示
  list            全ノード一覧
  help            このヘルプを表示

Options:
  --no-tokens     グラフ出力でトークン数を非表示

Examples:
  cd ~/.claude/plugins/dev && loom check
  cd ~/.claude/plugins/dev && loom reverse worker-structure
  loom update-svgs
EOF
}

# サブコマンドなしまたは help
if [ $# -eq 0 ]; then
    show_help
    exit 0
fi

CMD="$1"
shift

case "$CMD" in
    check)
        python3 "$ENGINE" --check "$@"
        ;;
    validate)
        python3 "$ENGINE" --validate "$@"
        ;;
    tree)
        python3 "$ENGINE" --tree "$@"
        ;;
    orphans)
        python3 "$ENGINE" --orphans "$@"
        ;;
    complexity)
        python3 "$ENGINE" --complexity "$@"
        ;;
    update-readme)
        python3 "$ENGINE" --update-readme "$@"
        ;;
    audit|deep-validate)
        python3 "$ENGINE" --deep-validate "$@"
        ;;
    reverse)
        if [ $# -eq 0 ]; then
            echo "Error: reverse requires a target name" >&2
            exit 1
        fi
        python3 "$ENGINE" --reverse "$@"
        ;;
    target)
        if [ $# -eq 0 ]; then
            echo "Error: target requires a name" >&2
            exit 1
        fi
        python3 "$ENGINE" --target "$@"
        ;;
    graph)
        python3 "$ENGINE" --graphviz "$@"
        ;;
    mermaid)
        python3 "$ENGINE" --mermaid "$@"
        ;;
    tokens)
        python3 "$ENGINE" --tokens "$@"
        ;;
    list)
        python3 "$ENGINE" --list "$@"
        ;;
    update-svgs)
        # 全 plugin の SVG を一括再生成
        PLUGINS_DIR="$HOME/.claude/plugins"
        if [ ! -d "$PLUGINS_DIR" ]; then
            echo "Error: plugins directory not found at $PLUGINS_DIR" >&2
            exit 1
        fi

        success=0
        fail=0
        for plugin_dir in "$PLUGINS_DIR"/*/; do
            plugin_name="$(basename "$plugin_dir")"
            # スキップ対象
            case "$plugin_name" in
                _shared|cache|marketplaces) continue ;;
            esac
            # deps.yaml がなければスキップ
            [ -f "$plugin_dir/deps.yaml" ] || continue

            echo "--- $plugin_name ---"
            if (cd "$plugin_dir" && python3 "$ENGINE" --update-readme); then
                success=$((success + 1))
            else
                echo "  FAILED: $plugin_name" >&2
                fail=$((fail + 1))
            fi
        done

        echo ""
        echo "=== update-svgs complete: $success success, $fail failed ==="
        [ "$fail" -eq 0 ] || exit 1
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        echo "Error: unknown command '$CMD'" >&2
        echo "Run 'loom help' for usage" >&2
        exit 1
        ;;
esac
