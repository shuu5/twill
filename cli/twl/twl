#!/bin/bash
# twl - TWiLL framework CLI
# Wrapper around twl-engine.py (analyze-deps.py)
set -euo pipefail

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
ENGINE="$SCRIPT_DIR/twl-engine.py"

if [ ! -f "$ENGINE" ]; then
    echo "Error: twl-engine.py not found at $ENGINE" >&2
    exit 1
fi

show_help() {
    cat <<'EOF'
twl - TWiLL framework CLI

Usage: twl <command> [args]

Commands:
  rename <old> <new>       コンポーネント名を一括変更（4箇所 + v3.0 chain）
  promote <name> <type>    コンポーネントの型変更（昇格/降格 + セクション移動）
  check                    ファイル存在チェック
  validate        型ルール検証 (can_spawn/spawnable_by)
  rules           型ルールテーブルを表示 (types.yaml)
  sync-check      types.yaml と参照ドキュメントの差分を検出
  sync-docs       docs/ref-*.md をターゲットディレクトリに同期
  tree            ASCII ツリー出力
  orphans         未使用/孤立ノード検出
  complexity      7メトリクス複雑さレポート
  update-readme   SVG グラフ生成 + README.md 更新
  audit           TWiLL 準拠度の機械的チェック（5セクションレポート）
  deep-validate   深層検証（controller bloat, ref placement, tools）
  reverse <name>  逆依存関係を表示
  target <name>   依存関係を表示
  update-svgs     全 plugin の SVG を一括再生成
  chain generate  chain 定義から成果物を生成（テンプレート出力/書き込み/乖離検出）
  graph           Graphviz DOT 出力 (デフォルト)
  mermaid         Mermaid フローチャート出力
  tokens          トークン数を表示
  list            全ノード一覧
  help            このヘルプを表示

Options:
  --dry-run       変更内容のプレビュー（rename/promote で使用）
  --no-tokens     グラフ出力でトークン数を非表示

Examples:
  cd ~/.claude/plugins/twl && twl check
  cd ~/.claude/plugins/twl && twl reverse worker-structure
  twl rename old-name new-name
  twl rename old-name new-name --dry-run
  twl promote my-action controller
  twl promote my-action controller --dry-run
  twl update-svgs
  twl rules
  twl sync-check --ref docs/ref-types.md
  twl sync-docs ~/.claude/plugins/twl/refs/
  twl sync-docs ~/.claude/plugins/twl/refs/ --check
  twl chain generate my-chain
  twl chain generate --check --all
EOF
}

# サブコマンドなしまたは help
if [ $# -eq 0 ]; then
    show_help
    exit 0
fi

CMD="$1"
shift

case "$CMD" in
    rename)
        if [ $# -lt 2 ]; then
            echo "Error: rename requires <old-name> <new-name>" >&2
            echo "Usage: twl rename <old-name> <new-name> [--dry-run]" >&2
            exit 1
        fi
        OLD_NAME="$1"
        NEW_NAME="$2"
        shift 2
        # remaining args (e.g. --dry-run) passed through
        python3 "$ENGINE" --rename "$OLD_NAME" "$NEW_NAME" "$@"
        ;;
    promote)
        if [ $# -lt 2 ]; then
            echo "Error: promote requires <name> <new-type>" >&2
            echo "Usage: twl promote <name> <new-type> [--dry-run]" >&2
            exit 1
        fi
        COMP_NAME="$1"
        NEW_TYPE="$2"
        shift 2
        python3 "$ENGINE" --promote "$COMP_NAME" "$NEW_TYPE" "$@"
        ;;
    check)
        python3 "$ENGINE" --check "$@"
        ;;
    validate)
        python3 "$ENGINE" --validate "$@"
        ;;
    rules)
        python3 "$ENGINE" --rules "$@"
        ;;
    sync-check)
        if [ $# -eq 0 ] || [ "$1" != "--ref" ]; then
            echo "Error: sync-check requires --ref <path>" >&2
            echo "Usage: twl sync-check --ref <path>" >&2
            exit 1
        fi
        shift
        if [ $# -eq 0 ]; then
            echo "Error: --ref requires a file path" >&2
            exit 1
        fi
        python3 "$ENGINE" --sync-check "$1"
        ;;
    sync-docs)
        if [ $# -eq 0 ]; then
            echo "Error: sync-docs requires <target-dir>" >&2
            echo "Usage: twl sync-docs <target-dir> [--check]" >&2
            exit 1
        fi
        TARGET_DIR="$1"
        shift
        # --check flag maps to engine's --check + --sync-docs
        if [ "${1:-}" = "--check" ]; then
            python3 "$ENGINE" --sync-docs "$TARGET_DIR" --check
        else
            python3 "$ENGINE" --sync-docs "$TARGET_DIR" "$@"
        fi
        ;;
    tree)
        python3 "$ENGINE" --tree "$@"
        ;;
    orphans)
        python3 "$ENGINE" --orphans "$@"
        ;;
    complexity)
        python3 "$ENGINE" --complexity "$@"
        ;;
    update-readme)
        python3 "$ENGINE" --update-readme "$@"
        ;;
    audit)
        python3 "$ENGINE" --audit "$@"
        ;;
    deep-validate)
        python3 "$ENGINE" --deep-validate "$@"
        ;;
    reverse)
        if [ $# -eq 0 ]; then
            echo "Error: reverse requires a target name" >&2
            exit 1
        fi
        python3 "$ENGINE" --reverse "$@"
        ;;
    target)
        if [ $# -eq 0 ]; then
            echo "Error: target requires a name" >&2
            exit 1
        fi
        python3 "$ENGINE" --target "$@"
        ;;
    graph)
        python3 "$ENGINE" --graphviz "$@"
        ;;
    mermaid)
        python3 "$ENGINE" --mermaid "$@"
        ;;
    tokens)
        python3 "$ENGINE" --tokens "$@"
        ;;
    list)
        python3 "$ENGINE" --list "$@"
        ;;
    chain)
        if [ $# -eq 0 ]; then
            echo "Error: chain requires a subcommand (e.g. generate)" >&2
            echo "Usage: twl chain generate <chain-name> [--write|--check|--all]" >&2
            exit 1
        fi
        python3 "$ENGINE" chain "$@"
        ;;
    update-svgs)
        # 全 plugin の SVG を一括再生成
        PLUGINS_DIR="$HOME/.claude/plugins"
        if [ ! -d "$PLUGINS_DIR" ]; then
            echo "Error: plugins directory not found at $PLUGINS_DIR" >&2
            exit 1
        fi

        success=0
        fail=0
        for plugin_dir in "$PLUGINS_DIR"/*/; do
            plugin_name="$(basename "$plugin_dir")"
            # スキップ対象
            case "$plugin_name" in
                _shared|cache|marketplaces) continue ;;
            esac
            # deps.yaml がなければスキップ
            [ -f "$plugin_dir/deps.yaml" ] || continue

            echo "--- $plugin_name ---"
            if (cd "$plugin_dir" && python3 "$ENGINE" --update-readme); then
                success=$((success + 1))
            else
                echo "  FAILED: $plugin_name" >&2
                fail=$((fail + 1))
            fi
        done

        echo ""
        echo "=== update-svgs complete: $success success, $fail failed ==="
        [ "$fail" -eq 0 ] || exit 1
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        echo "Error: unknown command '$CMD'" >&2
        echo "Run 'twl help' for usage" >&2
        exit 1
        ;;
esac
