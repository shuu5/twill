#!/usr/bin/env bash
# deltaspec - Lightweight bash CLI for managing delta specs
# Architecture specs (permanent) + delta specs (changes) management
set -euo pipefail

DELTASPEC_VERSION="0.1.0"

# ── Colors ──────────────────────────────────────────────────────────
if [[ -t 1 ]] && [[ "${NO_COLOR:-}" != "1" ]] && [[ "${TERM:-}" != "dumb" ]]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[0;33m'
    CYAN='\033[0;36m'
    BOLD='\033[1m'
    DIM='\033[2m'
    RESET='\033[0m'
else
    RED='' GREEN='' YELLOW='' CYAN='' BOLD='' DIM='' RESET=''
fi

# ── Utility functions ───────────────────────────────────────────────

die() { echo -e "${RED}Error: $*${RESET}" >&2; exit 1; }
warn() { echo -e "${YELLOW}Warning: $*${RESET}" >&2; }
info() { echo -e "- $*"; }

# Simple YAML key-value parser (handles "key: value" format only)
yaml_get() {
    local file="$1" key="$2"
    grep -m1 "^${key}:" "$file" 2>/dev/null | sed "s/^${key}:[[:space:]]*//"
}

# Find openspec/ directory by walking up from cwd
find_openspec_root() {
    local dir="$PWD"
    while [[ "$dir" != "/" ]]; do
        if [[ -d "$dir/openspec" ]]; then
            echo "$dir"
            return 0
        fi
        dir="$(dirname "$dir")"
    done
    return 1
}

# JSON string escaping
json_escape() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# ── openspec root detection ─────────────────────────────────────────

OPENSPEC_ROOT=""
CHANGES_DIR=""
SPECS_DIR=""

init_paths() {
    OPENSPEC_ROOT="$(find_openspec_root)" || die "openspec/ directory not found. Run from a project with openspec/ initialized."
    CHANGES_DIR="$OPENSPEC_ROOT/openspec/changes"
    SPECS_DIR="$OPENSPEC_ROOT/openspec/specs"
}

# ── Subcommand: new ─────────────────────────────────────────────────

cmd_new() {
    local subcmd="${1:-}"
    shift || true

    case "$subcmd" in
        change) cmd_new_change "$@" ;;
        "") die "Usage: deltaspec new change <name>" ;;
        *) die "Unknown: deltaspec new $subcmd. Usage: deltaspec new change <name>" ;;
    esac
}

cmd_new_change() {
    local name="${1:-}"
    [[ -z "$name" ]] && die "Usage: deltaspec new change <name>"

    # Validate kebab-case
    if ! [[ "$name" =~ ^[a-z0-9]([a-z0-9-]*[a-z0-9])?$ ]]; then
        die "Change name must be kebab-case (lowercase letters, numbers, hyphens): $name"
    fi

    init_paths
    local change_dir="$CHANGES_DIR/$name"

    [[ -d "$change_dir" ]] && die "Change '$name' already exists at $change_dir/"

    mkdir -p "$change_dir"
    cat > "$change_dir/.openspec.yaml" <<EOF
schema: spec-driven
created: $(date +%Y-%m-%d)
EOF

    echo -e "- Creating change '${name}'..."
    echo -e "${GREEN}✔${RESET} Created change '${name}' at openspec/changes/${name}/ (schema: spec-driven)"
}

# ── Subcommand: status ──────────────────────────────────────────────

cmd_status() {
    local change_name="" json_mode=false schema_name=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --change) change_name="$2"; shift 2 ;;
            --schema) schema_name="$2"; shift 2 ;;
            --json) json_mode=true; shift ;;
            *) shift ;;
        esac
    done

    init_paths
    [[ -z "$change_name" ]] && die "Usage: deltaspec status --change <name>"

    local change_dir="$CHANGES_DIR/$change_name"
    [[ -d "$change_dir" ]] || die "Change '$change_name' not found"

    # Read schema from .openspec.yaml
    if [[ -z "$schema_name" ]] && [[ -f "$change_dir/.openspec.yaml" ]]; then
        schema_name="$(yaml_get "$change_dir/.openspec.yaml" "schema")"
    fi
    schema_name="${schema_name:-spec-driven}"

    # Determine artifact status (spec-driven schema)
    # Dependencies: proposal → design, specs (parallel) → tasks
    local proposal_done=false design_done=false specs_done=false tasks_done=false

    [[ -f "$change_dir/proposal.md" ]] && proposal_done=true
    [[ -f "$change_dir/design.md" ]] && design_done=true
    # specs: at least one directory under specs/ with a spec.md
    if [[ -d "$change_dir/specs" ]] && ls "$change_dir/specs"/*/spec.md >/dev/null 2>&1; then
        specs_done=true
    fi
    [[ -f "$change_dir/tasks.md" ]] && tasks_done=true

    # Calculate statuses
    local proposal_status design_status specs_status tasks_status

    proposal_status="ready"
    $proposal_done && proposal_status="done"

    if $proposal_done; then
        design_status="ready"
    else
        design_status="blocked"
    fi
    $design_done && design_status="done"

    if $proposal_done; then
        specs_status="ready"
    else
        specs_status="blocked"
    fi
    $specs_done && specs_status="done"

    if $design_done && $specs_done; then
        tasks_status="ready"
    else
        tasks_status="blocked"
    fi
    $tasks_done && tasks_status="done"

    local is_complete=false
    $proposal_done && $design_done && $specs_done && $tasks_done && is_complete=true

    # Count done artifacts
    local done_count=0
    $proposal_done && ((done_count++)) || true
    $design_done && ((done_count++)) || true
    $specs_done && ((done_count++)) || true
    $tasks_done && ((done_count++)) || true

    if $json_mode; then
        # JSON output
        echo "- Loading change status..."

        # Build missingDeps arrays
        local design_deps="" specs_deps="" tasks_deps=""
        if [[ "$design_status" == "blocked" ]]; then
            design_deps='"proposal"'
        fi
        if [[ "$specs_status" == "blocked" ]]; then
            specs_deps='"proposal"'
        fi
        if [[ "$tasks_status" == "blocked" ]]; then
            local deps_arr=()
            $design_done || deps_arr+=("\"design\"")
            $specs_done || deps_arr+=("\"specs\"")
            tasks_deps="$(IFS=,; echo "${deps_arr[*]}")"
        fi

        # Build artifacts JSON
        local artifacts=""
        artifacts+="    {\"id\": \"proposal\", \"outputPath\": \"proposal.md\", \"status\": \"$proposal_status\"}"

        artifacts+=","$'\n'"    {"
        artifacts+="\"id\": \"design\", \"outputPath\": \"design.md\", \"status\": \"$design_status\""
        [[ -n "$design_deps" ]] && artifacts+=", \"missingDeps\": [$design_deps]"
        artifacts+="}"

        artifacts+=","$'\n'"    {"
        artifacts+="\"id\": \"specs\", \"outputPath\": \"specs/**/*.md\", \"status\": \"$specs_status\""
        [[ -n "$specs_deps" ]] && artifacts+=", \"missingDeps\": [$specs_deps]"
        artifacts+="}"

        artifacts+=","$'\n'"    {"
        artifacts+="\"id\": \"tasks\", \"outputPath\": \"tasks.md\", \"status\": \"$tasks_status\""
        [[ -n "$tasks_deps" ]] && artifacts+=", \"missingDeps\": [$tasks_deps]"
        artifacts+="}"

        cat <<ENDJSON
{
  "changeName": "$change_name",
  "schemaName": "$schema_name",
  "isComplete": $is_complete,
  "applyRequires": [
    "tasks"
  ],
  "artifacts": [
$artifacts
  ]
}
ENDJSON
    else
        echo "- Loading change status..."
        echo "Change: $change_name"
        echo "Schema: $schema_name"
        echo "Progress: $done_count/4 artifacts complete"
        echo ""
        $proposal_done && echo "[x] proposal" || echo "[ ] proposal"
        $design_done && echo "[x] design" || echo "[ ] design"
        $specs_done && echo "[x] specs" || echo "[ ] specs"
        $tasks_done && echo "[x] tasks" || echo "[ ] tasks"
        echo ""
        if $is_complete; then
            echo "All artifacts complete!"
        else
            echo "Some artifacts still pending."
        fi
    fi
}

# ── Subcommand: list ────────────────────────────────────────────────

cmd_list() {
    local json_mode=false sort_order="recent"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) json_mode=true; shift ;;
            --sort) sort_order="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    init_paths

    local changes=()
    if [[ -d "$CHANGES_DIR" ]]; then
        while IFS= read -r d; do
            local name
            name="$(basename "$d")"
            [[ "$name" == "archive" ]] && continue
            changes+=("$name")
        done < <(find "$CHANGES_DIR" -mindepth 1 -maxdepth 1 -type d | sort)
    fi

    if [[ ${#changes[@]} -eq 0 ]]; then
        if $json_mode; then
            echo '{"changes": []}'
        else
            echo "No changes found."
        fi
        return 0
    fi

    # Collect change info
    local -a names=() statuses=() completed=() totals=() mtimes=()
    for name in "${changes[@]}"; do
        local change_dir="$CHANGES_DIR/$name"
        local tasks_file="$change_dir/tasks.md"
        local total=0 complete=0 status="pending"

        if [[ -f "$tasks_file" ]]; then
            total=$(grep -c '^\- \[[ x]\]' "$tasks_file" 2>/dev/null || true)
            total=${total:-0}
            complete=$(grep -c '^\- \[x\]' "$tasks_file" 2>/dev/null || true)
            complete=${complete:-0}
            if [[ $total -gt 0 ]] && [[ $complete -eq $total ]]; then
                status="complete"
            elif [[ $complete -gt 0 ]]; then
                status="in-progress"
            fi
        fi

        # Get modification time
        local mtime
        mtime="$(stat -c %Y "$change_dir" 2>/dev/null || echo 0)"

        names+=("$name")
        statuses+=("$status")
        completed+=("$complete")
        totals+=("$total")
        mtimes+=("$mtime")
    done

    # Sort
    local -a indices=()
    for i in "${!names[@]}"; do indices+=("$i"); done

    if [[ "$sort_order" == "name" ]]; then
        IFS=$'\n' indices=($(for i in "${indices[@]}"; do echo "$i ${names[$i]}"; done | sort -k2 | awk '{print $1}'))
    else
        # recent: sort by mtime descending
        IFS=$'\n' indices=($(for i in "${indices[@]}"; do echo "$i ${mtimes[$i]}"; done | sort -k2 -rn | awk '{print $1}'))
    fi

    if $json_mode; then
        echo '{'
        echo '  "changes": ['
        local first=true
        for i in "${indices[@]}"; do
            $first || echo ','
            first=false
            local iso_date
            iso_date="$(date -u -d "@${mtimes[$i]}" +%Y-%m-%dT%H:%M:%S.000Z 2>/dev/null || echo "unknown")"
            printf '    {"name": "%s", "completedTasks": %s, "totalTasks": %s, "lastModified": "%s", "status": "%s"}' \
                "${names[$i]}" "${completed[$i]}" "${totals[$i]}" "$iso_date" "${statuses[$i]}"
        done
        echo ''
        echo '  ]'
        echo '}'
    else
        echo "Changes:"
        for i in "${indices[@]}"; do
            local display
            if [[ "${statuses[$i]}" == "complete" ]]; then
                display="${DIM}✓ Complete${RESET}"
            else
                display="${completed[$i]}/${totals[$i]} tasks"
            fi

            # Relative time
            local now mtime_val ago rel_time
            now=$(date +%s)
            mtime_val="${mtimes[$i]}"
            ago=$((now - mtime_val))
            if [[ $ago -lt 60 ]]; then
                rel_time="just now"
            elif [[ $ago -lt 3600 ]]; then
                rel_time="$((ago / 60))m ago"
            elif [[ $ago -lt 86400 ]]; then
                rel_time="$((ago / 3600))h ago"
            else
                rel_time="$((ago / 86400))d ago"
            fi

            printf "  %-45s %-18b %s\n" "${names[$i]}" "$display" "$rel_time"
        done
    fi
}

# ── Subcommand: archive ─────────────────────────────────────────────

cmd_archive() {
    local change_name="" skip_specs=false yes_mode=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --skip-specs) skip_specs=true; shift ;;
            -y|--yes) yes_mode=true; shift ;;
            -*) shift ;;
            *) [[ -z "$change_name" ]] && change_name="$1"; shift ;;
        esac
    done

    [[ -z "$change_name" ]] && die "Usage: deltaspec archive <change-name> [-y] [--skip-specs]"

    init_paths
    local change_dir="$CHANGES_DIR/$change_name"
    [[ -d "$change_dir" ]] || die "Change '$change_name' not found"

    local archive_dir="$CHANGES_DIR/archive"

    # Confirmation
    if ! $yes_mode; then
        echo "Archive change '$change_name'?"
        if ! $skip_specs; then
            echo "This will update main specs in openspec/specs/."
        fi
        read -rp "Continue? [y/N] " answer
        [[ "$answer" =~ ^[yY]$ ]] || { echo "Cancelled."; return 0; }
    fi

    # Spec integration (unless --skip-specs)
    if ! $skip_specs; then
        _archive_integrate_specs "$change_dir"
    fi

    # Move to archive
    mkdir -p "$archive_dir"
    mv "$change_dir" "$archive_dir/$change_name"
    echo -e "${GREEN}✔${RESET} Archived change '$change_name'"
}

_archive_integrate_specs() {
    local change_dir="$1"
    local specs_dir_change="$change_dir/specs"

    [[ -d "$specs_dir_change" ]] || return 0

    for cap_dir in "$specs_dir_change"/*/; do
        [[ -d "$cap_dir" ]] || continue
        local cap_name
        cap_name="$(basename "$cap_dir")"
        local spec_file="$cap_dir/spec.md"
        [[ -f "$spec_file" ]] || continue

        local target_dir="$SPECS_DIR/$cap_name"

        # Parse delta headers and apply
        if grep -q '## ADDED Requirements' "$spec_file"; then
            mkdir -p "$target_dir"
            # Extract ADDED block content and merge
            if [[ -f "$target_dir/spec.md" ]]; then
                # Append ADDED requirements to existing spec
                local added_content
                added_content="$(sed -n '/^## ADDED Requirements/,/^## \(MODIFIED\|REMOVED\|RENAMED\) Requirements/{ /^## \(MODIFIED\|REMOVED\|RENAMED\) Requirements/d; p; }' "$spec_file")"
                echo "" >> "$target_dir/spec.md"
                echo "$added_content" >> "$target_dir/spec.md"
            else
                # New spec — copy as-is, removing delta headers
                sed 's/^## ADDED Requirements/## Requirements/' "$spec_file" > "$target_dir/spec.md"
            fi
            info "Integrated ADDED specs for '$cap_name'"
        fi

        if grep -q '## MODIFIED Requirements' "$spec_file"; then
            mkdir -p "$target_dir"
            if [[ -f "$target_dir/spec.md" ]]; then
                # For MODIFIED, we need to find matching requirements and replace them
                # Simple approach: overwrite the entire spec with the modified version
                local modified_content
                modified_content="$(sed -n '/^## MODIFIED Requirements/,/^## \(ADDED\|REMOVED\|RENAMED\) Requirements/{ /^## \(ADDED\|REMOVED\|RENAMED\) Requirements/d; p; }' "$spec_file")"
                # Replace header and write
                echo "$modified_content" | sed 's/^## MODIFIED Requirements/## Requirements/' > "$target_dir/spec.md"
            fi
            info "Integrated MODIFIED specs for '$cap_name'"
        fi

        if grep -q '## REMOVED Requirements' "$spec_file"; then
            if [[ -d "$target_dir" ]]; then
                rm -rf "$target_dir"
                info "Removed spec '$cap_name'"
            fi
        fi
    done
}

# ── Subcommand: validate ────────────────────────────────────────────

cmd_validate() {
    local change_name="" validate_all=false validate_changes=false
    local strict=false json_mode=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all) validate_all=true; shift ;;
            --changes) validate_changes=true; shift ;;
            --strict) strict=true; shift ;;
            --json) json_mode=true; shift ;;
            -*) shift ;;
            *) [[ -z "$change_name" ]] && change_name="$1"; shift ;;
        esac
    done

    init_paths

    local -a targets=()
    if $validate_all || $validate_changes; then
        for d in "$CHANGES_DIR"/*/; do
            [[ -d "$d" ]] || continue
            local n
            n="$(basename "$d")"
            [[ "$n" == "archive" ]] && continue
            targets+=("$n")
        done
    elif [[ -n "$change_name" ]]; then
        targets+=("$change_name")
    else
        die "Usage: deltaspec validate <change-name> [--all] [--changes] [--strict] [--json]"
    fi

    local total_items=0 passed=0 failed=0
    local json_items=""

    for name in "${targets[@]}"; do
        local change_dir="$CHANGES_DIR/$name"
        [[ -d "$change_dir" ]] || { warn "Change '$name' not found, skipping."; continue; }

        ((total_items++)) || true
        local issues=()
        local start_ms
        start_ms=$(date +%s%N 2>/dev/null | cut -c1-13 || echo 0)

        # Validate specs
        if [[ -d "$change_dir/specs" ]]; then
            for spec_file in "$change_dir/specs"/*/spec.md; do
                [[ -f "$spec_file" ]] || continue
                local cap
                cap="$(basename "$(dirname "$spec_file")")"

                # Check delta headers
                if ! grep -qE '^## (ADDED|MODIFIED|REMOVED|RENAMED) Requirements' "$spec_file"; then
                    issues+=("$cap: Missing delta header (ADDED/MODIFIED/REMOVED/RENAMED Requirements)")
                fi

                # Check Requirement prefix
                if ! grep -q '^### Requirement:' "$spec_file"; then
                    issues+=("$cap: Missing '### Requirement:' prefix")
                fi

                # Check SHALL/MUST per requirement
                local in_req=false req_name="" has_keyword=false
                while IFS= read -r line; do
                    if [[ "$line" =~ ^'### Requirement:' ]]; then
                        if $in_req && ! $has_keyword; then
                            issues+=("$cap: Requirement '$req_name' missing SHALL/MUST keyword")
                        fi
                        in_req=true
                        req_name="${line#'### Requirement: '}"
                        has_keyword=false
                    elif $in_req; then
                        if echo "$line" | grep -qiE '\b(SHALL|MUST)\b'; then
                            has_keyword=true
                        fi
                    fi
                done < "$spec_file"
                # Check last requirement
                if $in_req && ! $has_keyword; then
                    issues+=("$cap: Requirement '$req_name' missing SHALL/MUST keyword")
                fi

                # Check Scenario blocks
                local in_req2=false req_name2="" has_scenario=false
                while IFS= read -r line; do
                    if [[ "$line" =~ ^'### Requirement:' ]]; then
                        if $in_req2 && ! $has_scenario; then
                            issues+=("$cap: Requirement '$req_name2' missing #### Scenario: block")
                        fi
                        in_req2=true
                        req_name2="${line#'### Requirement: '}"
                        has_scenario=false
                    elif [[ "$line" =~ ^'#### Scenario:' ]]; then
                        has_scenario=true
                    fi
                done < "$spec_file"
                if $in_req2 && ! $has_scenario; then
                    issues+=("$cap: Requirement '$req_name2' missing #### Scenario: block")
                fi
            done
        fi

        local end_ms
        end_ms=$(date +%s%N 2>/dev/null | cut -c1-13 || echo 0)
        local duration_ms=$(( (end_ms - start_ms) ))
        [[ $duration_ms -lt 0 ]] && duration_ms=0

        local valid=true
        if [[ ${#issues[@]} -gt 0 ]]; then
            valid=false
            ((failed++)) || true
        else
            ((passed++)) || true
        fi

        if $json_mode; then
            local issues_json="[]"
            if [[ ${#issues[@]} -gt 0 ]]; then
                issues_json="["
                local first_issue=true
                for issue in "${issues[@]}"; do
                    $first_issue || issues_json+=", "
                    first_issue=false
                    issues_json+="\"$(json_escape "$issue")\""
                done
                issues_json+="]"
            fi
            [[ -n "$json_items" ]] && json_items+=","$'\n'
            json_items+="    {\"id\": \"$name\", \"type\": \"change\", \"valid\": $valid, \"issues\": $issues_json, \"durationMs\": $duration_ms}"
        else
            if $valid; then
                echo -e "${GREEN}✔${RESET} $name: valid"
            else
                echo -e "${RED}✘${RESET} $name: ${#issues[@]} issue(s)"
                for issue in "${issues[@]}"; do
                    echo "  - $issue"
                done
            fi
        fi
    done

    if $json_mode; then
        cat <<ENDJSON
{
  "items": [
$json_items
  ],
  "summary": {
    "totals": {
      "items": $total_items,
      "passed": $passed,
      "failed": $failed
    },
    "byType": {
      "change": {
        "items": $total_items,
        "passed": $passed,
        "failed": $failed
      }
    }
  },
  "version": "1.0"
}
ENDJSON
    else
        echo ""
        echo "Summary: $passed passed, $failed failed out of $total_items"
    fi

    [[ $failed -eq 0 ]] && return 0 || return 1
}

# ── Subcommand: instructions ────────────────────────────────────────

cmd_instructions() {
    local artifact_id="" change_name="" schema_name="" json_mode=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --change) change_name="$2"; shift 2 ;;
            --schema) schema_name="$2"; shift 2 ;;
            --json) json_mode=true; shift ;;
            -*) shift ;;
            *) [[ -z "$artifact_id" ]] && artifact_id="$1"; shift ;;
        esac
    done

    [[ -z "$artifact_id" ]] && die "Usage: deltaspec instructions <artifact> --change <name> [--json]"
    [[ -z "$change_name" ]] && die "Usage: deltaspec instructions <artifact> --change <name> [--json]"

    init_paths
    local change_dir="$CHANGES_DIR/$change_name"
    [[ -d "$change_dir" ]] || die "Change '$change_name' not found"

    if [[ -z "$schema_name" ]] && [[ -f "$change_dir/.openspec.yaml" ]]; then
        schema_name="$(yaml_get "$change_dir/.openspec.yaml" "schema")"
    fi
    schema_name="${schema_name:-spec-driven}"

    # Artifact definitions for spec-driven schema
    local description="" output_path="" instruction="" template=""
    local -a deps=() unlocks=()

    case "$artifact_id" in
        proposal)
            description="Initial proposal document outlining the change"
            output_path="proposal.md"
            instruction='Create the proposal document that establishes WHY this change is needed.\n\nSections:\n- **Why**: 1-2 sentences on the problem or opportunity.\n- **What Changes**: Bullet list of changes.\n- **Capabilities**: New and Modified capabilities.\n- **Impact**: Affected code, APIs, dependencies.\n\nKeep it concise (1-2 pages). Focus on the \"why\" not the \"how\".'
            template='## Why\n\n## What Changes\n\n## Capabilities\n\n### New Capabilities\n\n### Modified Capabilities\n\n## Impact\n'
            unlocks=("design" "specs")
            ;;
        design)
            description="Technical design document with implementation details"
            output_path="design.md"
            instruction='Create the design document that explains HOW to implement the change.\n\nSections:\n- **Context**: Background and constraints\n- **Goals / Non-Goals**: Scope boundaries\n- **Decisions**: Key technical choices with rationale\n- **Risks / Trade-offs**: Known limitations'
            template='## Context\n\n## Goals / Non-Goals\n\n**Goals:**\n\n**Non-Goals:**\n\n## Decisions\n\n## Risks / Trade-offs\n'
            deps=("proposal")
            unlocks=("tasks")
            ;;
        specs)
            description="Detailed specifications for the change"
            output_path="specs/**/*.md"
            instruction='Create specification files that define WHAT the system should do.\n\nCreate one spec file per capability listed in the proposal.\n\nFormat:\n- Delta headers: ## ADDED/MODIFIED/REMOVED/RENAMED Requirements\n- Each requirement: ### Requirement: <name>\n- Use SHALL/MUST for normative requirements\n- Each scenario: #### Scenario: <name> with WHEN/THEN format'
            template='## ADDED Requirements\n\n### Requirement: <!-- name -->\n<!-- description -->\n\n#### Scenario: <!-- name -->\n- **WHEN** <!-- condition -->\n- **THEN** <!-- expected outcome -->\n'
            deps=("proposal")
            unlocks=("tasks")
            ;;
        tasks)
            description="Implementation checklist with trackable tasks"
            output_path="tasks.md"
            instruction='Create the task list that breaks down the implementation work.\n\nGuidelines:\n- Group related tasks under ## numbered headings\n- Each task MUST be a checkbox: - [ ] X.Y Task description\n- Tasks should be small enough to complete in one session\n- Order tasks by dependency'
            template='## 1. <!-- Group -->\n\n- [ ] 1.1 <!-- Task -->\n\n## 2. <!-- Group -->\n\n- [ ] 2.1 <!-- Task -->\n'
            deps=("design" "specs")
            ;;
        apply)
            # Special: apply instructions with task progress
            _instructions_apply "$change_name" "$change_dir" "$schema_name" "$json_mode"
            return
            ;;
        *)
            die "Unknown artifact: $artifact_id. Available: proposal, design, specs, tasks, apply"
            ;;
    esac

    # Build dependencies JSON
    local deps_json="["
    local first_dep=true
    for dep in "${deps[@]}"; do
        $first_dep || deps_json+=", "
        first_dep=false
        local dep_done=false dep_path=""
        case "$dep" in
            proposal) dep_path="proposal.md"; [[ -f "$change_dir/proposal.md" ]] && dep_done=true ;;
            design) dep_path="design.md"; [[ -f "$change_dir/design.md" ]] && dep_done=true ;;
            specs) dep_path="specs/**/*.md"; [[ -d "$change_dir/specs" ]] && ls "$change_dir/specs"/*/spec.md >/dev/null 2>&1 && dep_done=true ;;
        esac
        deps_json+="{\"id\": \"$dep\", \"done\": $dep_done, \"path\": \"$dep_path\"}"
    done
    deps_json+="]"

    local unlocks_json="["
    local first_unlock=true
    for u in "${unlocks[@]}"; do
        $first_unlock || unlocks_json+=", "
        first_unlock=false
        unlocks_json+="\"$u\""
    done
    unlocks_json+="]"

    if $json_mode; then
        echo "- Generating instructions..."
        cat <<ENDJSON
{
  "changeName": "$change_name",
  "artifactId": "$artifact_id",
  "schemaName": "$schema_name",
  "changeDir": "$change_dir",
  "outputPath": "$output_path",
  "description": "$description",
  "instruction": "$(json_escape "$(echo -e "$instruction")")",
  "template": "$(json_escape "$(echo -e "$template")")",
  "dependencies": $deps_json,
  "unlocks": $unlocks_json
}
ENDJSON
    else
        echo "Artifact: $artifact_id"
        echo "Output: $output_path"
        echo "Description: $description"
        echo ""
        echo -e "$instruction"
    fi
}

_instructions_apply() {
    local change_name="$1" change_dir="$2" schema_name="$3" json_mode="$4"
    local tasks_file="$change_dir/tasks.md"

    if [[ ! -f "$tasks_file" ]]; then
        if [[ "$json_mode" == "true" ]]; then
            echo '{"state": "blocked", "message": "tasks.md not found"}'
        else
            echo "tasks.md not found. Create artifacts first."
        fi
        return
    fi

    # Parse tasks
    local total=0 complete=0
    local -a task_ids=() task_descs=() task_dones=()
    local idx=0

    while IFS= read -r line; do
        if [[ "$line" =~ ^-\ \[([x\ ])\]\ (.+)$ ]]; then
            ((idx++)) || true
            local done_char="${BASH_REMATCH[1]}"
            local desc="${BASH_REMATCH[2]}"
            task_ids+=("$idx")
            task_descs+=("$desc")
            if [[ "$done_char" == "x" ]]; then
                task_dones+=("true")
                ((complete++)) || true
            else
                task_dones+=("false")
            fi
            ((total++)) || true
        fi
    done < "$tasks_file"

    local remaining=$((total - complete))
    local state="ready"
    [[ $remaining -eq 0 ]] && state="all_done"

    if [[ "$json_mode" == "true" ]]; then
        echo "- Generating apply instructions..."

        # Context files
        local ctx_proposal="$change_dir/proposal.md"
        local ctx_specs="$change_dir/specs/**/*.md"
        local ctx_design="$change_dir/design.md"
        local ctx_tasks="$change_dir/tasks.md"

        # Tasks JSON
        local tasks_json=""
        for i in "${!task_ids[@]}"; do
            [[ -n "$tasks_json" ]] && tasks_json+=","$'\n'
            tasks_json+="    {\"id\": \"${task_ids[$i]}\", \"description\": \"$(json_escape "${task_descs[$i]}")\", \"done\": ${task_dones[$i]}}"
        done

        cat <<ENDJSON
{
  "changeName": "$change_name",
  "changeDir": "$change_dir",
  "schemaName": "$schema_name",
  "contextFiles": {
    "proposal": "$ctx_proposal",
    "specs": "$ctx_specs",
    "design": "$ctx_design",
    "tasks": "$ctx_tasks"
  },
  "progress": {
    "total": $total,
    "complete": $complete,
    "remaining": $remaining
  },
  "tasks": [
$tasks_json
  ],
  "state": "$state",
  "instruction": "Read context files, work through pending tasks, mark complete as you go.\nPause if you hit blockers or need clarification."
}
ENDJSON
    else
        echo "Change: $change_name"
        echo "Progress: $complete/$total tasks complete ($remaining remaining)"
        echo ""
        for i in "${!task_ids[@]}"; do
            if [[ "${task_dones[$i]}" == "true" ]]; then
                echo "[x] ${task_descs[$i]}"
            else
                echo "[ ] ${task_descs[$i]}"
            fi
        done
    fi
}

# ── Main ────────────────────────────────────────────────────────────

show_help() {
    cat <<EOF
Usage: deltaspec [command] [options]

Lightweight CLI for managing delta specs

Commands:
  new change <name>           Create a new change directory
  status --change <name>      Show artifact completion status
  list                        List all changes
  archive <name>              Archive a completed change
  validate [name]             Validate spec syntax
  instructions <artifact>     Get artifact build instructions

Options:
  -V, --version               Show version
  -h, --help                  Show this help
  --no-color                  Disable color output
EOF
}

main() {
    local cmd="${1:-}"
    shift || true

    case "$cmd" in
        new)          cmd_new "$@" ;;
        status)       cmd_status "$@" ;;
        list)         cmd_list "$@" ;;
        archive)      cmd_archive "$@" ;;
        validate)     cmd_validate "$@" ;;
        instructions) cmd_instructions "$@" ;;
        -V|--version) echo "$DELTASPEC_VERSION" ;;
        -h|--help|"") show_help ;;
        *)
            echo -e "${RED}Error: Unknown command '$cmd'${RESET}" >&2
            echo "" >&2
            show_help >&2
            exit 1
            ;;
    esac
}

main "$@"
